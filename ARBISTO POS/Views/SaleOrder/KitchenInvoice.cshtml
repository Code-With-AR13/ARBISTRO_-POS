@model ARBISTO_POS.ViewModels.PosViewModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Kitchen Invoice - Order #@Model.Order.OrderNumber</title>
    
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { 
            font-family: 'Courier New', monospace; 
            padding: 20px; 
            background: white;
        }
        .invoice-container {
            max-width: 300px;
            margin: 0 auto;
            border: 2px dashed #000;
            padding: 15px;
        }
        .header {
            text-align: center;
            border-bottom: 2px solid #000;
            padding-bottom: 10px;
            margin-bottom: 10px;
        }
        .header h2 { font-size: 20px; margin-bottom: 5px; }
        .header p { font-size: 12px; }
        
        .order-info {
            margin-bottom: 15px;
            font-size: 12px;
        }
        .order-info p {
            margin: 5px 0;
            font-weight:bolder;
        }
        
        table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 10px;
            font-size: 11px;
        }
        table th {
            border-top: 1px solid #000;
            border-bottom: 1px solid #000;
            padding: 5px;
            text-align: left;
        }
        table td {
            padding: 5px;
            border-bottom: 1px dashed #ccc;
            font-weight:bolder;
        }
        
        .footer {
            text-align: center;
            border-top: 2px solid #000;
            padding-top: 10px;
            margin-top: 10px;
            font-size: 12px;
            font-weight: bold;
        }
        
        @@media print {
            .invoice-container {
                border: none;
                max-width: 100%;
            }
        }
    </style>
</head>
<body>
    <div class="invoice-container">
        <!-- Header -->
        <div class="header">
            <h2>🍴 KITCHEN ORDER 🍴</h2>
            <p>Order #@Model.Order.OrderNumber</p>
        </div>

        <!-- Order Information -->
        <div class="order-info">
            <p><strong>Date:</strong> @Model.Order.OrderDate.ToString("dd/MM/yyyy hh:mm tt")</p>
            <p><strong>Order Type:</strong> @Model.Order.OrderType</p>
            
            @if (Model.Order.Table != null)
            {
                <p><strong>Table:</strong> @Model.Order.Table.TabName</p>
            }                        
        </div>

        <!-- Order Items -->
        <table>
            <thead>
                <tr>
                    <th>Item</th>
                    <th style="text-align: center;">Qty</th>
                    <th>Notes</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Order.OrderItems)
                {
                    <tr>
                        <td>@item.ItemName</td>
                        <td style="text-align: center;">@item.Quantity</td>
                        <td>-</td>
                    </tr>
                }
            </tbody>
        </table>

        <!-- Notes -->
        @if (!string.IsNullOrEmpty(Model.Order.Notes))
        {
            <div style="margin-top: 10px; padding: 10px; border: 1px solid #000;">
                <strong>Special Instructions:</strong><br />
                @Model.Order.Notes
            </div>
        }

        <!-- Footer -->
        <div class="footer">
            <p>⏰ PREPARE IMMEDIATELY ⏰</p>
            <p>Status: READY TO COOK</p>
        </div>
    </div>

    <!-- jQuery CDN -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    
    <!-- ✅ FIXED Auto Print Script -->
    <script type="text/javascript">
        // ✅ Solution 1: Wait for complete page load including images
        window.onload = function() {
            // Page fully load hone ke baad 500ms wait karo
            setTimeout(function() {
                window.print();
            }, 500);
        };

        // ✅ Solution 2: Print dialog close hone ke baad window close karo
        window.onafterprint = function() {
            // Print dialog close hone ke baad window close ho
            setTimeout(function() {
                window.close();
            }, 500);
        };

        // ✅ Solution 3: Agar user print cancel kare to bhi window close ho
        window.onbeforeprint = function() {
            console.log('Print dialog opened');
        };
    </script>
</body>
</html>
