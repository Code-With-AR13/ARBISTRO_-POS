@model ARBISTO_POS.Models.ServiceTables

@{
    ViewData["Title"] = "Edit Service Table";
}

<!-- [ page-header ] start -->
<div class="page-header">
    <div class="page-header-left d-flex align-items-center">
        <ul class="breadcrumb">
            <li class="breadcrumb-item">
                <a asp-controller="Home" asp-action="Index">Home</a>
            </li>
            <li class="breadcrumb-item">
                <a asp-controller="ServiceTables" asp-action="Index">Service Tables</a>
            </li>
            <li class="breadcrumb-item active">Edit</li>
        </ul>
    </div>
    <div class="page-header-right ms-auto">
        <div class="d-flex align-items-center gap-2 page-header-right-items-wrapper">
            <a asp-controller="ServiceTables" asp-action="Index" class="btn btn-primary">
                <i class="feather-arrow-left me-2"></i>
                <span>Back To Tables</span>
            </a>
        </div>
    </div>
</div>
<!-- [ page-header ] end -->
<!-- [ Main Content ] start -->
<div class="main-content">
    <div class="row">
        <div class="col-lg-12">
            <div class="card border-top-0">
                <div class="card-header">
                    <h5 class="card-title">
                        <i class="feather-edit-3 me-2"></i>Edit Service Table
                    </h5>
                </div>

                <div class="card-body">

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <form asp-action="Edit"
                          asp-controller="ServiceTables"
                          method="post"
                          enctype="multipart/form-data">

                        <!-- hidden -->
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="TabImage" />

                        <div class="row">

                            <!-- LEFT COLUMN - IMAGE -->
                            <div class="col-lg-4 mb-4">
                                <div class="card bg-light">
                                    <div class="card-body text-center">
                                        <label class="form-label fw-semibold">Table Image</label>

                                        <div class="position-relative mx-auto" style="width:200px;height:200px;">
                                            <div class="border border-2 border-dashed rounded-3 overflow-hidden h-100 w-100 position-relative bg-white"
                                                 id="avatarDiv"
                                                 style="cursor:pointer;">
                                                <img id="avatarPreview"
                                                     src="@(string.IsNullOrEmpty(Model.TabImage)
                                                                                                    ? Url.Content("~/assets/images/tables.jpg")
                                                                                                                 : Model.TabImage)"
                                                     class="img-fluid h-100 w-100"
                                                     style="object-fit:cover;" />
                                                <div class="position-absolute start-0 top-0 w-100 h-100 d-flex align-items-center justify-content-center bg-dark bg-opacity-50"
                                                     id="uploadOverlay"
                                                     style="opacity:0;transition:opacity .3s;">
                                                    <i class="feather-camera text-white" style="font-size:32px;"></i>
                                                </div>
                                            </div>
                                            <input asp-for="ImageFile"
                                                   type="file"
                                                   id="fileInput"
                                                   accept="image/png,image/jpg,image/jpeg"
                                                   style="display:none;" />
                                        </div>

                                        <div class="mt-3">
                                            <small class="text-muted d-block">Click image to change</small>
                                            <small class="text-muted d-block">PNG, JPG, JPEG (Max 2MB)</small>
                                            <small class="text-muted d-block">YOU CAN ALSO UPDATE THIS IMAGE.</small>
                                        </div>

                                        <span asp-validation-for="ImageFile" class="text-danger small"></span>
                                    </div>
                                </div>
                            </div>

                            <!-- RIGHT COLUMN -->
                            <div class="col-lg-8">

                                <!-- TABLE NAME -->
                                <div class="mb-3">
                                    <label asp-for="TabName" class="form-label fw-semibold">
                                        Table Name <span class="text-danger">*</span>
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text">
                                            <i class="feather-tag"></i>
                                        </span>
                                        <input asp-for="TabName"
                                               class="form-control"
                                               placeholder="e.g. Table 01, VIP Table" />
                                    </div>
                                    <span asp-validation-for="TabName" class="text-danger small"></span>
                                </div>

                                <!-- DESCRIPTION -->
                                <div class="mb-3">
                                    <label asp-for="TabDescription" class="form-label fw-semibold">
                                        Description
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text">
                                            <i class="feather-file-text"></i>
                                        </span>
                                        <textarea asp-for="TabDescription"
                                                  class="form-control"
                                                  rows="4"
                                                  placeholder="Near window, 6 persons capacity..."></textarea>
                                    </div>
                                    <span asp-validation-for="TabDescription" class="text-danger small"></span>
                                </div>

                                <!-- ACTIONS -->
                                <div class="d-flex gap-2 justify-content-end mt-4">
                                    <a asp-action="Index" class="btn btn-light">
                                        <i class="feather-x me-1"></i>Cancel
                                    </a>
                                    <button type="submit" class="btn btn-primary">
                                        <i class="feather-save me-1"></i>Update Table
                                    </button>
                                </div>

                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- [ Main Content ] end -->
@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        $(document).ready(function () {

            const avatarDiv = $('#avatarDiv');
            const fileInput = $('#fileInput');
            const avatarPreview = $('#avatarPreview');
            const uploadOverlay = $('#uploadOverlay');

            avatarDiv.on('click', () => fileInput.click());

            avatarDiv.hover(
                () => uploadOverlay.css('opacity', '1'),
                () => uploadOverlay.css('opacity', '0')
            );

            fileInput.on('change', function (e) {
                const file = e.target.files[0];
                if (!file) return;

                if (file.size > 2 * 1024 * 1024) {
                    alert('File size must be less than 2MB');
                    fileInput.val('');
                    return;
                }

                const validTypes = ['image/png', 'image/jpg', 'image/jpeg'];
                if (!validTypes.includes(file.type)) {
                    alert('Only PNG, JPG, JPEG allowed');
                    fileInput.val('');
                    return;
                }

                const reader = new FileReader();
                reader.onload = e => avatarPreview.attr('src', e.target.result);
                reader.readAsDataURL(file);
            });
        });
    </script>
}
