@model ARBISTO_POS.Models.Employees

@{
    ViewData["Title"] = "Create Employee";
}

<!-- [ page-header ] start -->
<div class="page-header">
    <div class="page-header-left d-flex align-items-center">
        <ul class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li class="breadcrumb-item"><a asp-controller="Employees" asp-action="Index">Employees</a></li>
            <li class="breadcrumb-item active">Create</li>
        </ul>
    </div>
    <div class="page-header-right ms-auto">
        <div class="d-flex align-items-center gap-2 page-header-right-items-wrapper">
            <a asp-controller="Employees" asp-action="Index" class="btn btn-primary">
                <i class="feather-arrow-left me-2"></i>
                <span>Back To Employees</span>
            </a>
        </div>
    </div>
</div>
<!-- [ page-header ] end -->
<!-- [ Main Content ] start -->
<div class="main-content">
    <div class="row">
        <div class="col-lg-12">
            <div class="card border-top-0">
                <div class="card-header">
                    <h5 class="card-title">
                        <i class="feather-plus-circle me-2"></i>Create New Employee
                    </h5>
                </div>

                <div class="card-body">
                    <!-- Success/Error Messages -->
                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="feather-check-circle me-2"></i>@TempData["SuccessMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    <!-- Validation Summary -->
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <form method="post" enctype="multipart/form-data" id="employeeForm">
                        <div class="row">
                            <!-- Left Column - Image Upload -->
                            <div class="col-lg-4 mb-4">
                                <div class="card bg-light">
                                    <div class="card-body text-center">
                                        <label class="form-label fw-semibold">Employee Image</label>

                                        <div class="position-relative mx-auto" style="width: 200px; height: 200px;">
                                            <div class="border border-2 border-dashed rounded-3 overflow-hidden h-100 w-100 position-relative bg-white" id="avatarDiv" style="cursor: pointer;">
                                                <img id="avatarPreview" src="~/assets/images/upload.jpg" class="img-fluid h-100 w-100" style="object-fit: cover;" alt="Upload Image">
                                                <div class="position-absolute start-0 top-0 w-100 h-100 d-flex align-items-center justify-content-center bg-dark bg-opacity-50" id="uploadOverlay" style="opacity: 0; transition: opacity 0.3s;">
                                                    <i class="feather-camera text-white" style="font-size: 32px;"></i>
                                                </div>
                                            </div>
                                            <input type="file" accept="image/png,image/jpg,image/jpeg" asp-for="ImageFile" id="fileInput" style="display: none;" />
                                        </div>

                                        <div class="mt-3">
                                            <small class="text-muted d-block"><i class="feather-info me-1"></i>Click image to upload</small>
                                            <small class="text-muted d-block">Size: 150x150px (Max 2MB)</small>
                                            <small class="text-muted d-block">Format: PNG, JPG, JPEG</small>
                                        </div>
                                        <span asp-validation-for="ImageFile" class="text-danger small"></span>
                                    </div>
                                </div>
                            </div>

                            <!-- Right Column - Form Fields -->
                            <div class="col-lg-8">
                                <!-- Full Name -->
                                <div class="mb-3">
                                    <label asp-for="FullName" class="form-label fw-semibold">
                                        Full Name <span class="text-danger">*</span>
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="feather-user"></i></span>
                                        <input type="text" class="form-control" asp-for="FullName" placeholder="John Doe" />
                                    </div>
                                    <span asp-validation-for="FullName" class="text-danger small"></span>
                                </div>

                                <!-- Date of Birth -->
                                <div class="mb-3">
                                    <label asp-for="DateOfBirth" class="form-label fw-semibold">Date of Birth</label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="feather-calendar"></i></span>
                                        <input type="date" class="form-control" asp-for="DateOfBirth" />
                                    </div>
                                </div>

                                <!-- Gender -->
                                <div class="mb-3">
                                    <label asp-for="Gender" class="form-label fw-semibold">Gender</label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="feather-users"></i></span>
                                        <select class="form-select" asp-for="Gender">
                                            <option value="">Select Gender</option>
                                            <option value="Male">Male</option>
                                            <option value="Female">Female</option>
                                            <option value="Other">Other</option>
                                        </select>
                                    </div>
                                </div>

                                <!-- Email -->
                                <div class="mb-3">
                                    <label asp-for="Email" class="form-label fw-semibold">Email</label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="feather-mail"></i></span>
                                        <input type="email" class="form-control" asp-for="Email" placeholder="example@mail.com" />
                                    </div>
                                    <span asp-validation-for="Email" class="text-danger small"></span>
                                </div>

                                <!-- Phone -->
                                <div class="mb-3">
                                    <label asp-for="PhoneNumber" class="form-label fw-semibold">Phone Number</label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="feather-phone"></i></span>
                                        <input type="text" class="form-control" asp-for="PhoneNumber" placeholder="03001234567" />
                                    </div>
                                    <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                                </div>

                                <!-- Address -->
                                <div class="mb-3">
                                    <label asp-for="Address" class="form-label fw-semibold">Address</label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="feather-map-pin"></i></span>
                                        <textarea class="form-control" asp-for="Address" placeholder="City Street No Mohala"></textarea>
                                    </div>
                                </div>

                                <!-- Shift -->
                                <div class="mb-3">
                                    <label asp-for="Shift" class="form-label fw-semibold">Shift</label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="feather-clock"></i></span>
                                        <input type="text" class="form-control" asp-for="Shift" placeholder="Morning / Evening" />
                                    </div>
                                </div>

                                <!-- Role -->
                                <div class="mb-3">
                                    <label asp-for="EmpRole" class="form-label fw-semibold">Role</label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="feather-users"></i></span>
                                        <select class="form-select" asp-for="EmpRole">
                                            <option value="">-- Select Role --</option>                                           
                                            <option value="Manager">Manager</option>
                                            <option value="Cashier">Cashier</option>                                           
                                            <option value="Waiter">Waiter</option>
                                            <option value="Chef">Chef</option>                                            
                                            <option value="DeliveryRider">Delivery Rider</option>
                                            <option value="Cleaner">Cleaner</option>
                                        </select>
                                        <span asp-validation-for="EmpRole" class="text-danger small"></span>
                                    </div>
                                </div>

                                <!-- Salary -->
                                <div class="mb-3">
                                    <label asp-for="Salary" class="form-label fw-semibold">Salary</label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="feather-dollar-sign"></i></span>
                                        <input type="number" class="form-control" asp-for="Salary" placeholder="2000000" />
                                    </div>
                                </div>

                                <!-- Emergency Contact -->
                                <div class="mb-3">
                                    <label asp-for="EmergencyContactName" class="form-label fw-semibold">Emergency Contact Name</label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="feather-phone"></i></span>
                                        <input type="text" class="form-control" asp-for="EmergencyContactName" placeholder="Asim" />
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="EmergencyContactPhone" class="form-label fw-semibold">Emergency Contact Phone</label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="feather-phone"></i></span>
                                        <input type="text" class="form-control" asp-for="EmergencyContactPhone" placeholder="+92389284323" />
                                    </div>
                                </div>

                                <!-- Description -->
                                <div class="mb-3">
                                    <label asp-for="Discription" class="form-label fw-semibold">Description</label>
                                    <div class="input-group">
                                        <span class="input-group-text">
                                            <i class="feather-file-text"></i>
                                        </span>
                                        <textarea class="form-control" asp-for="Discription" placeholder="Waiter etc......"></textarea>
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="IsActive" class="form-label fw-semibold">Status</label>

                                    <div class="form-check form-switch">
                                        <input class="form-check-input"
                                               type="checkbox"
                                               asp-for="IsActive"
                                               id="IsActiveSwitch" checked />
                                        <label class="form-check-label" for="IsActiveSwitch">
                                            Active
                                        </label>
                                    </div>
                                </div>


                                <!-- Form Actions -->
                                <div class="d-flex gap-2 justify-content-end mt-4">
                                    <a asp-action="Index" class="btn btn-light">
                                        <i class="feather-x me-1"></i>Cancel
                                    </a>
                                    <button type="submit" class="btn btn-primary">
                                        <i class="feather-save me-1"></i>Save Employee
                                    </button>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- [ Main Content ] end -->
@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        $(document).ready(function() {
            const avatarDiv = $('#avatarDiv');
            const fileInput = $('#fileInput');
            const avatarPreview = $('#avatarPreview');
            const uploadOverlay = $('#uploadOverlay');

            avatarDiv.on('click', function() {
                fileInput.click();
            });

            avatarDiv.on('mouseenter', function() {
                uploadOverlay.css('opacity', '1');
            }).on('mouseleave', function() {
                uploadOverlay.css('opacity', '0');
            });

            fileInput.on('change', function(e) {
                const file = e.target.files[0];

                if (file) {
                    if (file.size > 2 * 1024 * 1024) {
                        alert('File size must be less than 2MB');
                        fileInput.val('');
                        return;
                    }

                    const validTypes = ['image/png', 'image/jpg', 'image/jpeg'];
                    if (!validTypes.includes(file.type)) {
                        alert('Only PNG, JPG, and JPEG files are allowed');
                        fileInput.val('');
                        return;
                    }

                    const reader = new FileReader();
                    reader.onload = function(event) {
                        avatarPreview.attr('src', event.target.result);
                        avatarDiv.addClass('border-success');
                        setTimeout(() => {
                            avatarDiv.removeClass('border-success');
                        }, 1000);
                    };
                    reader.readAsDataURL(file);
                }
            });
        });
    </script>
}
