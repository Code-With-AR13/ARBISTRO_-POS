@{
    ViewData["Title"] = "Kitchen";   
}
<main class="nxl-container-fluid">
    @Html.AntiForgeryToken()
    <div class="nxl-content">
        <!-- Page Header -->
        <div class="page-header">
            <div class="page-header-left d-flex align-items-center">
                <div class="page-header-title">
                    <h5 class="m-b-10">Kitchen</h5>
                </div>
                <ul class="breadcrumb">
                    <li class="breadcrumb-item">
                        <a asp-controller="Home" asp-action="Index">Home</a>
                    </li>
                    <li class="breadcrumb-item active">Kitchen</li>
                </ul>
            </div>
            <div class="page-header-right ms-auto">
                <div class="d-flex align-items-center gap-2 page-header-right-items-wrapper">
                    <a asp-controller="SaleOrder" asp-action="Create" class="btn btn-primary">
                        <i class="feather-plus me-2"></i>
                        <span>New Sale Order</span>
                    </a>
                </div>               
            </div>
        </div>
    </div>
</main>
@{
    var chefs = (List<ARBISTO_POS.Models.Employees>)ViewBag.Chefs;
}

<script>
    const chefsList = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                chefs.Select(c => new { id = c.Id, name = c.FullName })
        ));
</script>
<div class="row">
@foreach (var order in Model)
{
        <div class="col-md-6 col-lg-6 px-4 mt-3">
        <div class="card mb-3 order-card"
             data-order-id="@order.OrderId"
             id="orderCard_@order.OrderId">

            <div class="card-body">
                <!-- Order Header -->
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div>
                        <h5 class="mb-1">Order #@order.OrderNumber</h5>
                        <small class="text-muted">Customer: @order.CustomerId</small><br>
                        <small class="text-muted">
                            Date: @order.OrderDate.ToString("dd-MM-yyyy HH:mm:ss")
                        </small>
                    </div>
                        @if (order.OrderType == "DINE IN")
                        {
                            <span class="badge bg-primary">Dine In</span>
                        }
                        else if (order.OrderType == "PICKUP POINT")
                        {
                            <span class="badge bg-secondary">Pickup Point</span>
                        }
                        else if (order.OrderType == "DELIVERY")
                        {
                            <span class="badge bg-success">Delivery</span>
                        }
                    </div>

                <!-- Chef Selection -->
                <div class="mb-3">
                    <label class="form-label">Assign Chef:</label>
                    <select class="form-select chef-select"
                            id="chefSelect_@order.OrderId"
                            data-order-id="@order.OrderId">
                        <option value="">Select Chef</option>
                        @foreach (var chef in ViewBag.Chefs)
                        {
                            <option value="@chef.Id">@chef.FullName</option>
                        }
                    </select>
                    <small class="text-muted" id="chefStatus_@order.OrderId"></small>
                </div>

                <!-- Order Items -->
                <div class="order-items mb-3">
                    @foreach (var item in order.OrderItems)
                    {
                        <div class="form-check mb-2">
                            <input class="form-check-input item-checkbox p-2"
                                   type="checkbox"
                                   value="@item.ItemId"
                                   id="item_@order.OrderId@item.ItemId"
                                   data-order-id="@order.OrderId">
                            <label class="form-check-label"
                                   for="item_@order.OrderId@item.ItemId">
                                @item.Quantity x @item.ItemName
                            </label>
                        </div>
                    }
                </div>

                <!-- Progress Bar -->
                <div class="progress mb-3" style="height: 10px;">
                    <div class="progress-bar progress-bar-striped progress-bar-animated"
                         role="progressbar"
                         id="progress_@order.OrderId"
                         style="width: 0%">
                    </div>
                </div>

                <small class="text-muted d-block mb-3 text-center">
                    Progress: <span id="progress-text_@order.OrderId">0%</span>
                </small>

                <!-- Status Message -->
                <div class="status-message alert alert-success d-none text-center"
                     id="statusMessage_@order.OrderId">
                    <i class="fas fa-check-circle me-2"></i>
                    Order is Ready and has been sent!
                </div>
            </div>
        </div>
    </div>
}
</div>


@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            console.log('Kitchen page loaded');

                 // ✅ AUTO-SELECT FIRST CHEF FOR EACH ORDER
        document.querySelectorAll('.chef-select').forEach(select => {
            const orderId = select.dataset.orderId;
            const firstChefOption = select.querySelector('option[value]:not([value=""])');

            if (firstChefOption) {
                const chefId = firstChefOption.value;
                select.value = chefId; // Set dropdown to first chef

                // Automatically assign chef to order
                assignChefToOrder(orderId, chefId, function(success) {
                    const chefStatus = document.getElementById(`chefStatus_${orderId}`);
                    if (success) {
                        chefStatus.innerHTML = '<span class="text-success">Chef assigned</span>';
                    } else {
                        chefStatus.innerHTML = '<span class="text-danger">Failed to assign chef</span>';
                    }
                });
            }
        });
            // Initialize progress for each order
            document.querySelectorAll('.order-card').forEach(card => {
                const orderId = card.dataset.orderId;
                updateProgress(orderId);
            });

            // Checkbox change event            
        //             document.addEventListener('change', function (e) {
        //     if (e.target.classList.contains('item-checkbox')) {
        //         const orderId = e.target.dataset.orderId;
        //         updateProgress(orderId);
        //         checkAndCompleteOrder(orderId);
        //     }
        // });
                document.addEventListener('change', function (e) {
            if (e.target.classList.contains('item-checkbox')) {

                const orderId = e.target.dataset.orderId;
                const itemName = e.target.nextElementSibling.innerText;

                updateProgress(orderId);
                checkAndCompleteOrder(orderId);

                // 🔥 SEND READY ITEM NOTIFICATION
                if (e.target.checked) {

                    fetch('/SaleOrder/NotifyItemReady', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded',
                            'RequestVerificationToken':
                                document.querySelector('input[name="__RequestVerificationToken"]').value
                        },
                        body: `orderId=${orderId}&itemName=${encodeURIComponent(itemName)}`
                    });
                }
            }
        });

            // Chef selection change event
                    document.addEventListener('change', function (e) {
            if (e.target.classList.contains('chef-select')) {

                const orderId = e.target.dataset.orderId;
                const chefId = e.target.value;
                const chefStatus = document.getElementById(`chefStatus_${orderId}`);

                if (chefId) {
                    assignChefToOrder(orderId, chefId, function(success) {
                        if (success) {
                            chefStatus.innerHTML = '<span class="text-success">Chef assigned</span>';
                            checkAndCompleteOrder(orderId);
                        } else {
                            chefStatus.innerHTML = '<span class="text-danger">Failed to assign chef</span>';
                        }
                    });
                } else {
                    chefStatus.innerHTML = '<span class="text-danger">Please select a chef</span>';
                }
            }
        });
        });

        function calculateProgress(orderId) {
            const checkboxes = document.querySelectorAll(`.item-checkbox[data-order-id="${orderId}"]`);
            if (checkboxes.length === 0) return 0;

            let checkedCount = 0;
            checkboxes.forEach(cb => {
                if (cb.checked) checkedCount++;
            });
            return (checkedCount / checkboxes.length) * 100;
        }

        function updateProgress(orderId) {
            const checkboxes = document.querySelectorAll(`.item-checkbox[data-order-id="${orderId}"]`);
            const progressBar = document.getElementById(`progress_${orderId}`);
            const progressText = document.getElementById(`progress-text_${orderId}`);

            if (checkboxes.length === 0) return;

            let checkedCount = 0;
            checkboxes.forEach(cb => {
                if (cb.checked) checkedCount++;
            });

            const progressPercentage = (checkedCount / checkboxes.length) * 100;
            progressBar.style.width = `${progressPercentage}%`;
            progressText.textContent = `${Math.round(progressPercentage)}%`;

            if (progressPercentage < 50) {
                progressBar.className = 'progress-bar progress-bar-striped progress-bar-animated bg-warning';
            } else if (progressPercentage < 100) {
                progressBar.className = 'progress-bar progress-bar-striped progress-bar-animated bg-info';
            } else {
                progressBar.className = 'progress-bar progress-bar-striped progress-bar-animated bg-success';
            }
        }

        function checkAndCompleteOrder(orderId) {
            const progressPercentage = calculateProgress(orderId);
            const chefSelect = document.getElementById(`chefSelect_${orderId}`);
            const chefId = chefSelect.value;

            // Check if both conditions are met: 100% progress + chef selected
            if (progressPercentage === 100 && chefId) {
                console.log(`Auto-completing order ${orderId}`);
                completeOrderAutomatically(orderId);
            } else if (progressPercentage === 100 && !chefId) {
                document.getElementById(`chefStatus_${orderId}`).innerHTML =
                    '<span class="text-warning"><strong>Please select a chef to complete order</strong></span>';
            }
        }

               function assignChefToOrder(orderId, chefId, callback) {
            console.log(`Assigning chef ${chefId} to order ${orderId}`);

            // Get antiforgery token
            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

            fetch('/SaleOrder/AssignChef', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': token
                },
                body: `orderId=${orderId}&chefId=${chefId}`
            })
            .then(response => {
                if (!response.ok) {
                    throw new Error(`HTTP ${response.status}`);
                }
                return response.json();
            })
            .then(data => {
                console.log('Chef assignment response:', data);
                if (callback) {
                    callback(data.success);
                }
            })
            .catch(error => {
                console.error('Error assigning chef:', error);
                if (callback) {
                    callback(false);
                }
            });
        }

               function completeOrderAutomatically(orderId) {
            const statusMessage = document.getElementById(`statusMessage_${orderId}`);
            statusMessage.classList.remove('d-none', 'alert-success', 'alert-danger');
            statusMessage.classList.add('alert-info');
            statusMessage.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Marking order as Ready...';

            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

            fetch('/SaleOrder/UpdateOrderStatus', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': token
                },
                body: `orderId=${orderId}&status=Ready`
            })
            .then(response => {
                if (!response.ok) {
                    throw new Error(`HTTP ${response.status}`);
                }
                return response.json();
            })
            .then(data => {
                console.log('Status update response:', data);

                if (data.success) {
                    statusMessage.classList.remove('alert-info');
                    statusMessage.classList.add('alert-success');
                    statusMessage.innerHTML = '<i class="fas fa-check-circle me-2"></i>Order is Ready and has been sent!';

                    // Disable all controls
                    document.querySelectorAll(`.item-checkbox[data-order-id="${orderId}"]`).forEach(cb => {
                        cb.disabled = true;
                    });
                    document.getElementById(`chefSelect_${orderId}`).disabled = true;

                    // Smooth fade out animation
                    const orderCard = document.getElementById(`orderCard_${orderId}`);
                    if (orderCard) {
                        orderCard.style.transition = 'all 0.8s ease-out';
                        orderCard.style.opacity = '0';
                        orderCard.style.transform = 'scale(0.9) translateY(-20px)';
                    }

                    // Page refresh after 1.5 seconds
                    setTimeout(() => {
                        window.location.reload();
                    }, 1000);
                } else {
                    statusMessage.classList.remove('alert-info');
                    statusMessage.classList.add('alert-danger');
                    statusMessage.innerHTML = `<i class="fas fa-exclamation-circle me-2"></i>Error: ${data.message}`;
                }
            })
            .catch(error => {
                console.error('Error updating status:', error);
                statusMessage.classList.remove('alert-info');
                statusMessage.classList.add('alert-danger');
                statusMessage.innerHTML = '<i class="fas fa-exclamation-circle me-2"></i>Network error occurred.';
            });
        }


    </script>
    <!-------------------------------------------------- Notification Script--------------------------------------------------------->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>

    <script>
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/notificationHub")
            .build();

        connection.on("ReceiveKitchenNotification", function (title, message) {

            // Play sound
            const audio = new Audio('/sounds/notification.mp3');
            audio.play();

            // Show toast notification
            toastr.info(message, title);

            console.log("Kitchen Notification Received");
        });

        connection.start().catch(err => console.error(err));
    </script>
    <!-------------------------------------------------- Ajax  Script--------------------------------------------------------->
    <script>
        let existingOrderIds = new Set();

        // Store initial order IDs
        document.querySelectorAll('.order-card').forEach(card => {
            existingOrderIds.add(card.dataset.orderId);
        });

        async function checkForNewOrders() {
            try {
                const response = await fetch('/SaleOrder/GetPreparingOrders');
                const orders = await response.json();

                orders.forEach(order => {

                    // Agar already page pe hai to skip
                    if (existingOrderIds.has(order.orderId.toString()))
                        return;

                    console.log("New Order Found:", order.orderNumber);

                    // Add to set
                    existingOrderIds.add(order.orderId.toString());

                    // Render card dynamically
                    renderNewOrderCard(order);

                    // Play sound
                    const audio = new Audio('/sounds/notification.mp3');
                    audio.play();

                    toastr.success("New Order Arrived!", "Kitchen Alert");
                });
            }
            catch (err) {
                console.error("Error checking orders:", err);
            }
        }

                function renderNewOrderCard(order) {

            let itemsHtml = "";

                    order.items.forEach(item => {

            const checkboxId = `item_${order.orderId}_${item.itemId}`;

            itemsHtml += `
                <div class="form-check mb-2">
                    <input class="form-check-input item-checkbox p-2"
                           type="checkbox"
                           value="${item.itemId}"
                           id="${checkboxId}"
                           data-order-id="${order.orderId}">
                    <label class="form-check-label"
                           for="${checkboxId}">
                        ${item.quantity} x ${item.itemName}
                    </label>
                </div>
            `;
        });

            // 🔥 Generate Chef Options
            let chefOptions = `<option value="">Select Chef</option>`;

            chefsList.forEach(chef => {
                chefOptions += `<option value="${chef.id}">${chef.name}</option>`;
            });

            const cardHtml = `
            <div class="col-md-6 col-lg-6 px-4 mt-3">
                <div class="card mb-3 order-card"
                     data-order-id="${order.orderId}"
                     id="orderCard_${order.orderId}">
                    <div class="card-body">

                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div>
                                <h5>Order #${order.orderNumber}</h5>
                                <small>Date: ${order.orderDate}</small>
                            </div>
                            <span class="badge bg-primary">${order.orderType}</span>
                        </div>

                        <!-- 🔥 Chef Dropdown Added -->
                        <div class="mb-3">
                            <label class="form-label">Assign Chef:</label>
                            <select class="form-select chef-select"
                                    id="chefSelect_${order.orderId}"
                                    data-order-id="${order.orderId}">
                                ${chefOptions}
                            </select>
                            <small class="text-muted" id="chefStatus_${order.orderId}"></small>
                        </div>

                        <div class="order-items mb-3">
                            ${itemsHtml}
                        </div>

                        <div class="progress mb-3" style="height: 10px;">
                            <div class="progress-bar progress-bar-striped progress-bar-animated"
                                 id="progress_${order.orderId}"
                                 style="width: 0%">
                            </div>
                        </div>

                        <small class="text-muted d-block mb-3 text-center">
                            Progress: <span id="progress-text_${order.orderId}">0%</span>
                        </small>

                        <div class="status-message alert alert-success d-none text-center"
                             id="statusMessage_${order.orderId}">
                            <i class="fas fa-check-circle me-2"></i>
                            Order is Ready and has been sent!
                        </div>

                    </div>
                </div>
            </div>
            `;

            document.querySelector('.row').insertAdjacentHTML('afterbegin', cardHtml);

            // 🔥 AUTO SELECT FIRST CHEF FOR AJAX CARD
setTimeout(() => {

    const select = document.getElementById(`chefSelect_${order.orderId}`);
    const firstChefOption = select.querySelector('option[value]:not([value=""])');

    if (firstChefOption) {
        const chefId = firstChefOption.value;
        select.value = chefId;

        assignChefToOrder(order.orderId, chefId, function(success) {
            const chefStatus = document.getElementById(`chefStatus_${order.orderId}`);
            if (success) {
                chefStatus.innerHTML = '<span class="text-success">Chef assigned</span>';
            } else {
                chefStatus.innerHTML = '<span class="text-danger">Failed to assign chef</span>';
            }
        });
    }

    updateProgress(order.orderId);

}, 100);
        }

        // Check every 5 seconds
        setInterval(checkForNewOrders, 5000);
    </script>
}
