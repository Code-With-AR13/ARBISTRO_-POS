@model IEnumerable<ARBISTO_POS.Models.UserRole>

@{
    ViewData["Title"] = "User Roles";
}

<main class="nxl-container-fluid">
    <div class="nxl-content">
        <!-- Page Header -->
        <div class="page-header">
            <div class="page-header-left d-flex align-items-center">
                <div class="page-header-title">
                    <h5 class="m-b-10">User Roles</h5>
                </div>
                <ul class="breadcrumb">
                    <li class="breadcrumb-item">
                        <a asp-controller="Home" asp-action="Index">Home</a>
                    </li>
                    <li class="breadcrumb-item active">User Roles</li>
                </ul>
            </div>
            <div class="page-header-right ms-auto">
                <div class="d-flex align-items-center gap-2 page-header-right-items-wrapper">
                    <a asp-controller="UserRole" asp-action="Manage" class="btn btn-primary">
                        <i class="feather-plus me-2"></i>
                        <span>New User Role</span>
                    </a>
                </div>
            </div>
        </div>

        @if (TempData["ToastrSuccess"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="feather-check-circle me-2"></i>@TempData["ToastrSuccess"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <div class="main-content">
            <div class="row">
                <div class="col-lg-12">
                    <div class="card stretch stretch-full">
                        <div class="card-header">
                            <h5 class="card-title mb-0">
                                <i class="feather-list me-2"></i>All User Roles
                            </h5>
                        </div>

                        <div class="card-body p-0">
                            <div class="table-responsive">
                                <table class="table table-hover align-middle dataTable" id="rolesTable">
                                    <thead class="table-light">
                                        <tr>
                                            <th>User Role</th>
                                            <th>Active</th>
                                            <th>Permissions</th>
                                            <th class="text-center" style="width:120px;">Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @* AJAX will load data here *@
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>

@section Scripts {
    <script>
        $(document).ready(function () {

            var table = $('#rolesTable').DataTable({
                "processing": true,
                "serverSide": false,
                "ajax": {
                    "url": "/UserRole/GetAll", // ⚠️ Create this action in controller
                    "type": "GET",
                    "dataSrc": ""
                },
                "columns": [
                    {
                        "data": null,
                        "render": function (data) {
                            return `
                                <div class="d-flex flex-column">
                                    <span class="fw-semibold">${data.name}</span>
                                    <small class="text-muted">Created At: ${data.createdAt}</small>
                                </div>`;
                        }
                    },
                    {
                        "data": "isActive",
                        "render": function (data) {
                            return data
                                ? '<span class="badge bg-success">Active</span>'
                                : '<span class="badge bg-secondary">Inactive</span>';
                        }
                    },
                    {
                        "data": "permissions",
                        "render": function (data) {
                            if (!data || data.length === 0)
                                return '<span class="text-muted fst-italic">No permissions</span>';

                            let text = data.slice(0, 5).join(", ");
                            if (data.length > 5) text += "...";

                            return `<span>${text}</span>`;
                        }
                    },
                    {
                        "data": null,
                        "orderable": false,
                        "className": "text-center",
                        "render": function (data) {

                            if (data.name === "Admin") {
                                return `
                                    <div class="d-inline-flex gap-1">
                                        <button class="btn btn-sm btn-light" disabled>
                                            <i class="feather-edit-3"></i>
                                        </button>
                                        <button class="btn btn-sm btn-light" disabled>
                                            <i class="feather-trash-2"></i>
                                        </button>
                                    </div>`;
                            }

                            return `
                                <div class="d-inline-flex gap-1">
                                    <a href="/UserRole/Manage/${data.id}"
                                       class="btn btn-sm btn-light">
                                        <i class="feather-edit-3"></i>
                                    </a>

                                    <form id="delete-form-${data.id}"
                                          action="/UserRole/Delete"
                                          method="post"
                                          class="d-none">
                                        <input name="__RequestVerificationToken"
                                               value="${$('input[name="__RequestVerificationToken"]').val()}" />
                                        <input type="hidden" name="id" value="${data.id}" />
                                    </form>

                                    <button class="btn btn-sm btn-light js-delete"
                                            data-id="${data.id}">
                                        <i class="feather-trash-2"></i>
                                    </button>
                                </div>`;
                        }
                    }
                ]
            });

            // DELETE (same as your old code)
            $(document).on('click', '.js-delete', function (e) {
                e.preventDefault();

                const id = $(this).data('id');
                const form = $('#delete-form-' + id);
                const token = $('input[name="__RequestVerificationToken"]').val();

                Swal.fire({
                    title: 'Are you sure?',
                    text: 'This role will be permanently deleted!',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#d33',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: 'Yes, delete it!'
                }).then((result) => {
                    if (result.isConfirmed) {
                        $.ajax({
                            url: form.attr('action'),
                            type: 'POST',
                            data: { id: id, __RequestVerificationToken: token },
                            success: function (res) {
                                if (res.success) {
                                    table.ajax.reload(); // ✅ reload via AJAX
                                    Swal.fire('Deleted!', res.message, 'success');
                                } else {
                                    Swal.fire('Error', res.message, 'error');
                                }
                            }
                        });
                    }
                });
            });

            setTimeout(() => $('.alert-success').fadeOut('slow'), 5000);
        });
    </script>
}