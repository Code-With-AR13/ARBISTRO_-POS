@{
    ViewData["Title"] = "Dashboard";
}

<div class="main-content">
    <div class="row">

        <!-- Total Orders -->
        <div class="col-xxl-3 col-md-6">
            <div class="card stretch stretch-full">
                <div class="card-body">
                    <div class="d-flex align-items-start justify-content-between mb-4">
                        <div class="d-flex gap-4 align-items-center">
                            <div class="avatar-text avatar-lg bg-gray-200">
                                <i class="feather-shopping-cart"></i>
                            </div>
                            <div>
                                <div class="fs-4 fw-bold text-dark" id="ordersText">0</div>
                                <h3 class="fs-13 fw-semibold">Total Orders</h3>
                            </div>
                        </div>
                        <i class="feather-more-vertical"></i>
                    </div>

                    <div class="progress mt-2 ht-3">
                        <div id="ordersProgress" class="progress-bar bg-primary" style="width: 0%"></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Total Paid -->
        <div class="col-xxl-3 col-md-6">
            <div class="card stretch stretch-full">
                <div class="card-body">
                    <div class="d-flex align-items-start justify-content-between mb-4">
                        <div class="d-flex gap-4 align-items-center">
                            <div class="avatar-text avatar-lg bg-warning-subtle">
                                <i class="feather-dollar-sign"></i>
                            </div>
                            <div>
                                <div class="fs-4 fw-bold text-dark" id="paidText">0</div>
                                <h3 class="fs-13 fw-semibold">Total Paid</h3>
                            </div>
                        </div>
                        <i class="feather-more-vertical"></i>
                    </div>

                    <div class="progress mt-2 ht-3">
                        <div id="paidProgress" class="progress-bar bg-warning" style="width: 0%"></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Total Unpaid -->
        <div class="col-xxl-3 col-md-6">
            <div class="card stretch stretch-full">
                <div class="card-body">
                    <div class="d-flex align-items-start justify-content-between mb-4">
                        <div class="d-flex gap-4 align-items-center">
                            <div class="avatar-text avatar-lg bg-success-subtle">
                                <i class="feather-credit-card"></i>
                            </div>
                            <div>
                                <div class="fs-4 fw-bold text-dark" id="unpaidText">0</div>
                                <h3 class="fs-13 fw-semibold">Total Unpaid</h3>
                            </div>
                        </div>
                        <i class="feather-more-vertical"></i>
                    </div>

                    <div class="progress mt-2 ht-3">
                        <div id="unpaidProgress" class="progress-bar bg-success" style="width: 0%"></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Total Expense -->
        <div class="col-xxl-3 col-md-6">
            <div class="card stretch stretch-full">
                <div class="card-body">
                    <div class="d-flex align-items-start justify-content-between mb-4">
                        <div class="d-flex gap-4 align-items-center">
                            <div class="avatar-text avatar-lg bg-danger-subtle">
                                <i class="feather-pie-chart"></i>
                            </div>
                            <div>
                                <div class="fs-4 fw-bold text-dark">
                                    <span id="totalExpense">0</span> PKR
                                </div>
                                <h3 class="fs-13 fw-semibold">Total Expense</h3>
                            </div>
                        </div>
                        <i class="feather-more-vertical"></i>
                    </div>

                    <div class="progress mt-2 ht-3">
                        <div id="expenseProgress" class="progress-bar bg-danger" style="width: 0%"></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- GRAPH -->
        <div class="col-xxl-8">
            <div class="card stretch stretch-full">
                <div class="card-header">
                    <h5 class="card-title">Payment Record</h5>
                </div>
                <div class="card-body p-0">
                    <div id="payment-records-chart"></div>
                </div>
            </div>
        </div>

        <!-- LEADS OVERVIEW -->
        <div class="col-xxl-4">
            <div class="card stretch stretch-full">
                <div class="card-header">
                    <h5 class="card-title">Leads Overview</h5>
                </div>
                <div class="card-body">
                    <div id="leads-overview-donut"></div>
                </div>
            </div>
        </div>

        <!-- LATEST LEADS -->
        <div class="col-xxl-12">
            <div class="card stretch stretch-full">
                <div class="card-header">
                    <h5 class="card-title">Latest Leads</h5>
                </div>
                <div class="card-body">
                    <table id="latestLeadsTable" class="table table-striped">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Phone</th>
                                <th>Status</th>
                                <th>Date</th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
            </div>
        </div>

    </div>
</div>

@section Scripts {

   <script>
    let paymentChart = null;
    let leadsChart = null;
    let dashboardLoaded = false;

    $(document).ready(function () {

        // 🔥 REMOVE TEMPLATE CHARTS IMMEDIATELY
        $("#payment-records-chart").html("").find("*").remove();
        $("#leads-overview-donut").html("").find("*").remove();

        // 🔥 BLOCK TEMPLATE CHART ANIMATION / AUTO LOAD
        window.Apex = {
            chart: {
                animations: {
                    enabled: false
                }
            }
        };

        loadDashboard();
        loadTable();

        function loadDashboard() {

            if (dashboardLoaded) return;

            $.ajax({
                url: '/Home/GetDashboardData',
                type: 'GET',
                success: function (data) {

                    console.log("API DATA:", data); // 🔥 debug

                    dashboardLoaded = true;

                    // ✅ FIXED IDs (IMPORTANT)
                    $('#ordersText').text(data.totalOrders);
                    $('#paidText').text(data.totalPaid);
                    $('#unpaidText').text(data.totalUnpaid);
                    $('#totalExpense').text(data.totalExpense);

                    $('#paidProgress').css('width', data.paidPercent + '%');
                    $('#unpaidProgress').css('width', data.unpaidPercent + '%');
                    $('#ordersProgress').css('width', data.ordersPercent + '%');
                    $('#expenseProgress').css('width', data.expensePercent + '%');

                    // DESTROY SAFELY
                    if (paymentChart) {
                        paymentChart.destroy();
                        paymentChart = null;
                    }

                    if (leadsChart) {
                        leadsChart.destroy();
                        leadsChart = null;
                    }

                    let chartData = data.chartPayments.map(x => Number(x));
                    let chartDates = data.chartDates;

                    paymentChart = new ApexCharts(
                        document.querySelector("#payment-records-chart"),
                        {
                            chart: {
                                type: 'line',
                                height: 300
                            },
                            series: [{
                                name: 'Payments',
                                data: chartData
                            }],
                            xaxis: {
                                categories: chartDates
                            }
                        }
                    );

                    leadsChart = new ApexCharts(
                        document.querySelector("#leads-overview-donut"),
                        {
                            chart: {
                                type: 'donut',
                                height: 300
                            },
                            series: [
                                Number(data.totalPaid),
                                Number(data.totalUnpaid)
                            ],
                            labels: ["Paid", "Unpaid"]
                        }
                    );

                    // 🔥 DELAY RENDER TO OVERRIDE TEMPLATE
                    setTimeout(function () {
                        paymentChart.render();
                        leadsChart.render();
                    }, 200);
                }
            });
        }

        function loadTable() {

            if ($.fn.DataTable.isDataTable('#latestLeadsTable')) {
                $('#latestLeadsTable').DataTable().destroy();
            }

            $('#latestLeadsTable').DataTable({
                ajax: {
                    url: '/Home/GetLatestLeads',
                    type: 'GET',
                    dataSrc: 'data'
                },
                columns: [
                    { data: 'name' },
                    { data: 'phone' },
                    { data: 'status' },
                    { data: 'date' }
                ]
            });
        }

    });
</script>
}
    