<!---------------------------------------------------------- TABLE SELECTION MODAL -------------------------------------------------------------->
<div class="modal fade" id="tableSelectionModal" tabindex="-1" aria-labelledby="tableSelectionModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="tableSelectionModalLabel">Select Table</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="row g-3" id="tableListContainer">
                    <!-- Tables will be dynamically loaded here -->
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<!----------------------------------------------------------- FULL ADDRESS MODAL ---------------------------------------------------------------->
<div class="modal fade" id="fullAddressModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Shipping Address</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p id="fullAddressText" class="mb-0"></p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>               
            </div>
        </div>
    </div>
</div>

<!----------------------------------------------------------- PAYMENT MODAL ---------------------------------------------------------------->
<!-- PAYMENT MODAL - ENHANCED -->
<div class="modal fade" id="paymentModal" tabindex="-1" aria-labelledby="paymentModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-md modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="paymentModalLabel">
                    <i class="bi bi-credit-card me-2"></i>Payment Details
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                
                <!-- Total Amount Display -->
                <div class="alert alert-info mb-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <h6 class="mb-0"><i class="bi bi-receipt me-2"></i>Total Amount</h6>
                        <h4 class="mb-0 text-primary" id="paymentTotalAmount">0.00</h4>
                    </div>
                </div>

                <!-- Payment Method Selection -->
                <div class="mb-3">
                    <label for="paymentMethodSelect" class="form-label fw-semibold">
                        <i class="bi bi-cash-stack me-2"></i>Select Payment Method <span class="text-danger">*</span>
                    </label>
                    <select id="paymentMethodSelect" class="form-select form-select-lg" required>
                        <option value="">-- Select Payment Method --</option>
                        @foreach (var payment in Model.PaymentMethods)
                        {
                            <option value="@payment.Id" data-payment-name="@payment.PayName">
                                @payment.PayName
                            </option>
                        }
                    </select>
                </div>

                <!-- Received Amount -->
                <div class="mb-3">
                    <label for="receivedAmountInput" class="form-label fw-semibold">
                        <i class="bi bi-wallet2 me-2"></i>Received Amount
                    </label>
                    <input type="number" 
                           id="receivedAmountInput" 
                           class="form-control form-control-lg" 
                           placeholder="0.00" 
                           min="0" 
                           step="0.01" readonly />
                </div>
                <!-- 🔥 Order Status Hidden Field (Payment Check ke liye) -->
                 <input type="hidden" asp-for="Order.OrderStatus" id="OrderStatusHidden" value="@Model.Order.OrderStatus" />

                @* <!-- Change Amount Display -->
                <div class="alert alert-success mb-0">
                    <div class="d-flex justify-content-between align-items-center">
                        <h6 class="mb-0"><i class="bi bi-arrow-return-left me-2"></i>Change</h6>
                        <h4 class="mb-0 text-success" id="changeAmount">0.00</h4>
                    </div>
                </div> *@

            </div>  
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    Cancel
                </button>
                <!-- 🔥 PAYMENT BUTTON (Updated with Status Check) -->
                <button type="button" id="ConfirmpaymentBtn" class="btn btn-primary px-3 py-2 fs-6 ">
         Pay Now
    </button>
            </div>
        </div>
    </div>
</div>


@section Scripts {  
<!------------------------------------------------------------- TOASTER JS ---------------------------------------------------------------------->
<script>
        // Toastr Configuration - Right Top Corner
        toastr.options = {
            "closeButton": true,
            "debug": false,
            "newestOnTop": true,
            "progressBar": true,
            "positionClass": "toast-top-center",  // Right top corner
            "preventDuplicates": false,
            "onclick": null,
            "showDuration": "300",
            "hideDuration": "1000",
            "timeOut": "5000",
            "extendedTimeOut": "1000",
            "showEasing": "swing",
            "hideEasing": "linear",
            "showMethod": "fadeIn",
            "hideMethod": "fadeOut"
        };

        // Success Toaster Check karein
        @if (TempData["SuccessMessage"] != null)
        {
                <text>
                toastr.success('@TempData["SuccessMessage"]');
                </text>
        }
</script>
<!-------------------------------------------------------- PLACE  ORDER JS (SAME AS CREATE) ----------------------------------------------------->
<script>
    /* ===============================
       INITIALIZE ORDER FROM DATABASE
    =============================== */
    const currentOrder = @Html.Raw(Json.Serialize(Model.Order.OrderItems.Select(i => new {
        id = i.ItemId.ToString(),
        name = i.ItemName,
        price = i.Price,
        qty = i.Quantity,
        image = i.ItemImage 
    })));

    /* ===============================
       SELECT2 (Customers & Pickup)
    =============================== */
    $(document).ready(function () {

        $('.select2-ajax-category').select2({
            theme: 'bootstrap-5',
            placeholder: 'Select Customers',
            allowClear: true,
            ajax: {
                url: '@Url.Action("GetCustomers", "SaleOrder")',
                dataType: 'json',
                delay: 250,
                data: params => ({ search: params.term }),
                processResults: data => ({ results: data.results }),
                cache: true
            }
        });

        $('.select2-ajax-Pickup').select2({
            theme: 'bootstrap-5',
            placeholder: 'Select Pickup Points(OPT)',
            allowClear: true,
            ajax: {
                url: '@Url.Action("GetPickupPoints", "SaleOrder")',
                dataType: 'json',
                delay: 250,
                data: params => ({ search: params.term }),
                processResults: data => ({ results: data.results }),
                cache: true
            }
        });

        // Initial render
        renderOrder();
    });

    /* ===============================
       ORDER TYPE LOGIC
    =============================== */
    const tableDiv = document.getElementById('tableSelectDiv');
    const pickupDiv = document.getElementById('pickupSelectDiv');
    const deliveryDiv = document.getElementById('deliveryInputDiv');
    const orderTypeSelect = document.getElementById('orderTypeSelect');

    function hideAllOrderInputs() {
        tableDiv.classList.add('d-none');
        pickupDiv.classList.add('d-none');
        deliveryDiv.classList.add('d-none');
    }

    orderTypeSelect.addEventListener('change', () => {
        hideAllOrderInputs();
        document.getElementById('OrderTypeHidden').value = orderTypeSelect.value;

