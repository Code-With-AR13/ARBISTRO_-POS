<!-------------------------------------------------------- CATEGORY FILTER + SEARCH - FIXED FOR EDIT PAGE -------------------------------------------------------------->
<script>
document.addEventListener('DOMContentLoaded', function() {
    const searchBox = document.getElementById('itemSearch');
    const itemsGrid = document.getElementById('itemsGrid');
    const noItemsMsg = document.getElementById('noItemsMessage');
    
    /* ===============================
       CATEGORY FILTER (WITHOUT PAGE RELOAD)
    =============================== */
    document.querySelectorAll('.category-filter').forEach(categoryLink => {
        categoryLink.addEventListener('click', function(e) {
            e.preventDefault(); // ✅ Prevent page reload
            
            const selectedCategoryId = this.dataset.categoryId;
            
            console.log('🔄 Category clicked:', selectedCategoryId);
            
            // Update active class
            document.querySelectorAll('.category-filter').forEach(c => c.classList.remove('active'));
            this.classList.add('active');
            
            // Clear search
            searchBox.value = '';
            
            // Show/hide items based on category
            const allItems = document.querySelectorAll('.menu-item-wrapper');
            let visibleCount = 0;
            
            allItems.forEach((item, idx) => {
                const itemCategoryId = item.dataset.category;
                
                if (itemCategoryId === selectedCategoryId) {
                    // Show item from this category
                    item.setAttribute('style', `display: flex !important; visibility: visible !important; order: ${idx};`);
                    visibleCount++;
                } else {
                    // Hide item from other categories
                    item.setAttribute('style', 'display: none !important; visibility: hidden !important;');
                }
            });
            
            console.log(`✅ Showing ${visibleCount} items from category ${selectedCategoryId}`);
            
            // Handle no items message
            if (visibleCount === 0) {
                if (noItemsMsg) noItemsMsg.classList.remove('d-none');
                if (itemsGrid) itemsGrid.style.display = 'none';
            } else {
                if (noItemsMsg) noItemsMsg.classList.add('d-none');
                if (itemsGrid) itemsGrid.style.display = 'flex';
            }
        });
    });
    
    /* ===============================
       SEARCH FILTER (WORKS WITH CATEGORIES)
    =============================== */
    searchBox.addEventListener('keyup', function() {
        const searchValue = this.value.toLowerCase().trim();
        
        console.clear();
        console.log('='.repeat(50));
        console.log('🔍 SEARCH:', searchValue || '(empty)');
        console.log('='.repeat(50));
        
        // Get currently visible items (based on category filter)
        const allItems = Array.from(document.querySelectorAll('.menu-item-wrapper'));
        
        // Get active category
        const activeCategory = document.querySelector('.category-filter.active');
        const activeCategoryId = activeCategory ? activeCategory.dataset.categoryId : null;
        
        if (searchValue === '') {
            // Empty search - show all items from active category
            allItems.forEach((item, idx) => {
                const itemCategoryId = item.dataset.category;
                
                if (!activeCategoryId || itemCategoryId === activeCategoryId) {
                    item.setAttribute('style', `display: flex !important; visibility: visible !important; order: ${idx};`);
                } else {
                    item.setAttribute('style', 'display: none !important; visibility: hidden !important;');
                }
            });
            
            if (noItemsMsg) noItemsMsg.classList.add('d-none');
            if (itemsGrid) itemsGrid.style.display = 'flex';
            
            console.log('✅ Showing all items from active category');
            return;
        }
        
        // Search within active category
        const matchedItems = [];
        const unmatchedItems = [];
        
        allItems.forEach((item) => {
            const card = item.querySelector('.menu-item-card');
            const itemName = card.dataset.itemName.toLowerCase();
            const itemCategoryId = item.dataset.category;
            
            // Check if item is in active category AND matches search
            const isInActiveCategory = !activeCategoryId || itemCategoryId === activeCategoryId;
            const matchesSearch = itemName.includes(searchValue);
            
            if (isInActiveCategory && matchesSearch) {
                matchedItems.push(item);
                console.log(`✅ MATCHED: ${card.dataset.itemName}`);
            } else {
                unmatchedItems.push(item);
            }
        });
        
        console.log('='.repeat(50));
        console.log(`📊 Matched: ${matchedItems.length} | Hidden: ${unmatchedItems.length}`);
        console.log('='.repeat(50));
        
        // Show matched items FIRST
        matchedItems.forEach((item, idx) => {
            item.setAttribute('style', `display: flex !important; visibility: visible !important; order: ${idx};`);
        });
        
        // Hide unmatched items
        unmatchedItems.forEach((item) => {
            item.setAttribute('style', 'display: none !important; visibility: hidden !important; order: 9999;');
        });
        
        // Handle "no items found" message
        if (matchedItems.length === 0) {
            if (noItemsMsg) noItemsMsg.classList.remove('d-none');
            if (itemsGrid) itemsGrid.style.display = 'none';
            console.log('❌ No items found!');
        } else {
            if (noItemsMsg) noItemsMsg.classList.add('d-none');
            if (itemsGrid) itemsGrid.style.display = 'flex';
        }
    });
    
    // Trigger first category on page load
    const firstCategory = document.querySelector('.category-filter.active');
    if (firstCategory) {
        firstCategory.click();
    }
});
</script>
}
