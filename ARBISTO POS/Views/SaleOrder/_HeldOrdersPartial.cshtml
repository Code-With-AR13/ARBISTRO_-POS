@model List<ARBISTO_POS.Models.HeldOrders>
<div class="container-fluid">
    @if (Model == null || !Model.Any())
    {
        <div class="text-center text-muted py-5">
            <i class="feather-inbox fs-1 mb-3"></i>
            <h5 class="fw-semibold">No Held Orders</h5>
            <small>All held orders will appear here</small>
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var order in Model)
            {
                <div class="col-12">
                    <div class="card border border-light held-order-card">
                        <div class="card-body p-3">
                            <div class="row align-items-center">
                                <!-- Order Info Section -->
                                <div class="col-md-8">
                                    <div class="d-flex flex-column gap-2">
                                        <!-- Order Number & Type -->
                                        <div class="d-flex align-items-center gap-3">
                                            <h5 class="mb-0 fw-bold">Invoice #@order.OrderNumber</h5>
                                        </div>

                                        <!-- Customer & Items Info -->
                                        <div class="text-muted">
                                            <span>Customer: <strong class="text-dark">@(order.Customer?.Name ?? "Walk-in-Customer")</strong><span class="ms-3">(@(order.HeldOrderItems?.Count ?? 0) items)</span></span>                                           
                                        </div>
                                        
                                        <!-- Table Info (if Dine In) -->
                                        @if (order.OrderType == "DINE IN" && order.Table != null)
                                        {
                                            <div class="text-muted small">
                                                <i class="feather-grid me-1"></i>
                                                <span>Table: @order.Table.TabName</span>
                                            </div>
                                        }

                                        @* <!-- Date -->
                                        <div class="text-muted small">
                                            <i class="feather-clock me-1"></i>
                                            @order.OrderDate
                                        </div> *@
                                    </div>
                                </div>

                                <!-- Action Section -->
                                <div class="col-md-4 text-md-end mt-3 mt-md-0">
                                    <button type="button"
                                            class="btn btn-primary px-4"
                                            onclick="loadHeldOrder(@order.OrderId)">
                                        Restore
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

