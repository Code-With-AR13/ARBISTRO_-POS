@model ARBISTO_POS.ViewModels.PosViewModel
@{
    Layout = null;   // Print-style page
    var barcodeValue = $"{Model.Order.OrderNumber}-{Model.Order.OrderId}";
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Invoice - @Model.Order.OrderNumber</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
        body {
            background: #f5f5f5;
            font-size: 13px;
        }

        .invoice-wrapper {
            width: 80mm;
            margin: 10px auto;
            background: #fff;
            border: 1px solid #000;
            padding: 10px 8px 12px;
        }

        .store-logo { /* ...same as before... */ }
        .store-name { /* ...same as before... */ }
        .store-sub { /* ...same as before... */ }

        .barcode-box { border: 1px solid #000; padding: 4px 6px; margin: 6px auto 4px; text-align: center; max-width: 200px; }
        .barcode-text { font-size: 10px; }
        .info-row small { font-size: 11px; }

        table.invoice-items th,
        table.invoice-items td {
            border: 1px solid #000 !important;
            padding: 3px 4px !important;
            font-size: 11px;
        }

        table.invoice-items thead { background: #000; color: #fff; }

        .totals-table td { padding: 2px 4px !important; font-size: 11px; }
        .totals-table tr td:first-child { text-align: left; }
        .totals-table tr td:last-child { text-align: right; }

        .footer-text { font-size: 10px; text-align: center; }

        .btn-print { min-width: 90px; }

        @@media print {
            body {
                background: #fff;
                margin: 0;
                padding: 0;
            }

            .invoice-wrapper {
                width: 80mm;
                margin: 0;
                border: none;
                padding: 5mm;
            }

            .btn-print {
                display: none !important;
            }
        }

        @@page {
            size: 80mm auto;
            margin: 0;
        }

        .paid-stamp {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%) rotate(-18deg);
            padding: 12px 26px;
            border: 4px solid Black;
            color: black;
            font-weight: 800;
            font-size: 26px;
            text-transform: uppercase;
            opacity: 0.35;
            border-radius: 6px;
            letter-spacing: 3px;
        }

        .invoice-wrapper {
            position: relative;
            width: 80mm;
            margin: 10px auto;
            background: #fff;
            border: 1px solid #000;
            padding: 10px 8px 12px;
        }

    </style>

</head>
<body>
    <div class="invoice-wrapper">
        @if (Model.Order.PaymentStatus == "Paid")
        {
            <div class="paid-stamp">
                PAID
            </div>
        }

        <div class="text-center mb-1">
            <div class="store-logo">
                😊
            </div>
            <div class="store-name">ARBISTRO</div>
            <div class="store-sub">
                PASRUR SIALKOT 
            </div>
            <div class="store-sub">
                Phone: 03091986545 | Website: arbistro.com
            </div>
        </div>

        <div class="barcode-box border border-0">
            <img src="https://barcode.tec-it.com/barcode.ashx?data=@barcodeValue&amp;code=Code128&amp;translate-esc=true"
                 style="height:48px;width:180px;"
                 alt="Barcode" />
        </div>

        <div class="mt-2 mb-1">
            <div class="d-flex justify-content-between info-row">
                <small>Date:</small>
                <small>@Model.Order.OrderDate.ToString("dd/MM/yyyy")</small>
            </div>
            <div class="d-flex justify-content-between info-row">
                <small>Customer:</small>
                <small>@(Model.Order.Customer?.Name ?? "Walk-in Customer")</small>
            </div>
        </div>

        <div class="mt-2">
            <table class="table table-bordered table-sm mb-1 invoice-items">
                <thead class="table-dark">
                    <tr>
                        <th style="width:40%;">Product</th>
                        <th style="width:15%;" class="text-center">Qty</th>
                        <th style="width:20%;" class="text-end">Price</th>
                        <th style="width:25%;" class="text-end">Subtotal</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Order.OrderItems)
                    {
                        <tr>
                            <td>@item.ItemName</td>
                            <td class="text-center">@item.Quantity</td>
                            <td class="text-end">@item.Price.ToString("N2")</td>
                            <td class="text-end">@item.Total.ToString("N2")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <table class="w-100 totals-table mb-2">
            <tr>
                <td>Subtotal:</td>
                <td>@Model.Order.SubTotal.ToString("N2")</td>
            </tr>
            <tr>
                <td>Tax %:</td>
                <td>@Model.Order.TaxAmount</td>
            </tr>
            <tr>
                <td>Discount:</td>
                <td>@Model.Order.DiscountAmount</td>
            </tr>
            <tr>
                <td><strong>Total:</strong></td>
                <td><strong>@Model.Order.GrandTotal</strong></td>
            </tr>
        </table>

        <!-- ✅ UPDATED FOOTER (ONLY ADDITION HERE) -->
        <div class="footer-text mb-2">
            Thank you for choosing ARBISTRO
            <br />
            Website: Dynsof.com | Phone: 03208983255
        </div>

        <div class="d-flex justify-content-center gap-2">
            <button class="btn btn-dark btn-sm btn-print" onclick="window.print();">
                Print
            </button>
            <button class="btn btn-secondary btn-sm btn-print" type="button" onclick="goBackToIndex()">
                Cancel
            </button>
        </div>

    </div>

    <script>
        window.addEventListener('load', function () {
            window.print();
        });

        function goBackToIndex() {
            window.location.href = '@Url.Action("Index", "SaleOrder")';
        }
    </script>
</body>
</html>