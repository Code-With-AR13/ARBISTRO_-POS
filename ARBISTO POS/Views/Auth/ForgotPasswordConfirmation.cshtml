@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Check Your Email";
}

<main class="auth-creative-wrapper">
    <div class="auth-creative-inner">
        <div class="creative-card-wrapper" >
            <div class="card my-4 p-5 text-center overflow-hidden" style="z-index: 1">
                <h2 class="text-success mb-3">✓ Email Sent!</h2>
                <p>If your email is registered, you will receive a password reset link.</p>
                <p class="text-muted">Please check your inbox and spam folder.</p>
                <a asp-action="Login" class="btn btn-primary mt-3">Go to Login Page</a>
            </div>
        </div>
    </div>
</main>
