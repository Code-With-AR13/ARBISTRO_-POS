@using ARBISTO_POS.ViewModels
@model ExpenseReportVm
@{
    ViewData["Title"] = "Expense Report";
}

<main class="nxl-container-fluid">
    <div class="nxl-content">
        <!-- Header same as before -->
        <div class="page-header">
            <div class="page-header-left d-flex align-items-center">
                <div class="page-header-title">
                    <h5 class="m-b-10">Expense Report</h5>
                </div>
                <ul class="breadcrumb">
                    <li class="breadcrumb-item">
                        <a asp-controller="Home" asp-action="Index">Home</a>
                    </li>
                    <li class="breadcrumb-item active">Expense Report</li>
                </ul>
            </div>
        </div>

        <div class="main-content">

            <!-- Top Total Expense card -->
            <div class="row mb-4">
                <div class="col-xxl-3 col-md-6">
                    <div class="card stretch stretch-full">
                        <div class="card-body">
                            <div class="d-flex align-items-center mb-4">
                                <div class="me-3">
                                    <div class="d-flex align-items-center justify-content-center"
                                         style="width:48px;height:48px;border-radius:12px;
                                        background:linear-gradient(135deg,#ff9b6a,#ff7c6a);color:#fff;">
                                        <i class="feather-dollar-sign"></i>
                                    </div>
                                </div>
                                <div>
                                    <span class="text-uppercase fw-semibold" style="font-size:12px;">
                                        TOTAL EXPENSE
                                    </span>
                                </div>
                            </div>

                            <div class="d-flex align-items-center justify-content-between">
                                <div class="fw-bold" style="font-size:22px;">
                                    Rs @Model.TotalExpense.ToString("")
                                </div>
                                <span class="text-muted" style="font-size:13px;">Amount</span>
                            </div>

                            <div class="mt-2" style="height:2px;background:#ff7c6a;width:60%;"></div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Filter + result card -->
            <div class="row">
                <div class="col-12">
                    <div class="card" style="border-radius:10px;border:1px solid #2f7e9d40;">
                        <div class="card-body">

                            <!-- Filters row -->
                            <form method="get" class="row g-3 align-items-end mb-4" id="filterForm">

                                <div class="col-md-4">
                                    <label class="form-label fw-semibold" style="font-size:13px;">
                                        Expense Category
                                    </label>
                                    <select name="expenseTypeId" id="expenseTypeId" class="form-control">
                                        <option value="">All</option>
                                        @foreach (var t in Model.ExpenseTypes)
                                        {
                                            <option value="@t.Id" selected="@(t.Id == Model.ExpenseTypeId ? "selected" : null)">
                                                @t.ExpenseName
                                            </option>
                                        }
                                    </select>
                                </div>

                                <div class="col-md-4">
                                    <label class="form-label fw-semibold" style="font-size:13px;">
                                        Date Range
                                    </label>
                                    <div class="d-flex gap-2">
                                        <input type="date"
                                               id="fromDate"
                                               name="fromDate"
                                               value="@(Model.FromDate?.ToString("yyyy-MM-dd"))"
                                               class="form-control" />
                                        <input type="date"
                                               id="toDate"
                                               name="toDate"
                                               value="@(Model.ToDate?.ToString("yyyy-MM-dd"))"
                                               class="form-control" />
                                    </div>
                                </div>

                                <div class="col-md-4">
                                    <button type="submit"
                                            class="btn w-100 text-white btn-primary fs-6">
                                        Generate
                                    </button>
                                </div>

                            </form>

                            <!-- Result box -->
                            <div style="border:1px dashed #cfd8dc;border-radius:8px;min-height:220px;"
                                 class="d-flex align-items-center justify-content-center">

                                <div class="w-100 p-3">
                                    <div class="table-responsive">
                                        <table class="table dataTable table-sm mb-0">
                                            <thead class="table-light">
                                                <tr>
                                                    <th>Date</th>
                                                    <th>Expense Name</th>
                                                    <th>Expense Type</th>
                                                    <th class="text-end">Amount</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <!-- AJAX DATA -->
                                            </tbody>
                                        </table>
                                    </div>
                                </div>

                            </div>

                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</main>

@section Scripts {
    <script>
        $(document).ready(function () {

                   var table = $('.dataTable').DataTable({
            "ajax": {
                "url": "/ExpenseReports/GetReportData",
                "type": "GET",
                "data": function (d) {
                    d.expenseTypeId = $('#expenseTypeId').val() || null;
                    d.fromDate = $('#fromDate').val() || null;
                    d.toDate = $('#toDate').val() || null;
                },
                "error": function (xhr) {
                    console.log("ERROR:", xhr.responseText);
                }
            },
            "columns": [
                { "data": "createdDate" },
                { "data": "expenseName" },
                { "data": "expenseTypeName" },
                {
                    "data": "expenseAmount",
                    "className": "text-end",
                    "render": function (data) {
                        return data.toLocaleString();
                    }
                }
            ]
        });

        });
    </script>
}