@model IEnumerable<ARBISTO_POS.Models.ServiceTables>

@{
    ViewData["Title"] = "Service Tables";
}

<main class="nxl-container-fluid">
    <div class="nxl-content">
        <!-- Page Header -->
        <div class="page-header">
            <div class="page-header-left d-flex align-items-center">
                <div class="page-header-title">
                    <h5 class="m-b-10">Service Tables</h5>
                </div>
                <ul class="breadcrumb">
                    <li class="breadcrumb-item">
                        <a asp-controller="Home" asp-action="Index">Home</a>
                    </li>
                    <li class="breadcrumb-item active">Service Tables</li>
                </ul>
            </div>
            <div class="page-header-right ms-auto">
                <div class="d-flex align-items-center gap-2 page-header-right-items-wrapper">
                    <a asp-controller="ServiceTables" asp-action="Create" class="btn btn-primary">
                        <i class="feather-plus me-2"></i>
                        <span>New Table</span>
                    </a>
                </div>
            </div>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                <i class="feather-check-circle me-2"></i>
                <strong>Success!</strong> @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <div class="main-content">
            <div class="row">
                <div class="col-lg-12">
                    <div class="card stretch stretch-full">
                        <div class="card-header">
                            <h5 class="card-title mb-0">
                                <i class="feather-list me-2"></i>All Service Tables
                            </h5>
                        </div>

                        <div class="card-body p-0">
                            <div class="table-responsive">
                                <table class="table table-hover align-middle dataTable">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Table</th>
                                            <th>Description</th>
                                            <th class="text-center" style="width:120px;">Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (Model != null && Model.Any())
                                        {
                                            foreach (var table in Model)
                                            {
                                                <tr>
                                                    <td>
                                                        <div class="d-flex align-items-center">
                                                            <div class="me-3">
                                                                @if (!string.IsNullOrEmpty(table.TabImage))
                                                                {
                                                                    <img src="@table.TabImage"
                                                                         class="rounded-circle border"
                                                                         style="width:80px;height:80px;object-fit:cover;"
                                                                         onerror="this.src='/assets/images/upload.jpg'">
                                                                }
                                                                else
                                                                {
                                                                    <img src="~/assets/images/Tables.jpg"
                                                                         class="rounded-circle border"
                                                                         style="width:80px;height:80px;object-fit:cover;">
                                                                }
                                                            </div>
                                                            <div class="d-flex flex-column">
                                                                <span class="fw-semibold">@table.TabName</span>
                                                                <small class="text-muted">Created At: @table.CreatedDate</small>
                                                            </div>
                                                        </div>
                                                    </td>

                                                    <td>
                                                        @if (!string.IsNullOrEmpty(table.TabDescription))
                                                        {
                                                            @(table.TabDescription.Length > 80
                                                                                                            ? table.TabDescription.Substring(0, 80) + "..."
                                                                                                            : table.TabDescription)
                                                        }
                                                        else
                                                        {
                                                            <span class="text-muted fst-italic">No description</span>
                                                        }
                                                    </td>

                                                    <td class="text-center">
                                                        <div class="d-inline-flex gap-1">
                                                            <a asp-controller="ServiceTables"
                                                               asp-action="Edit"
                                                               asp-route-id="@table.Id"
                                                               class="btn btn-sm btn-light"
                                                               title="Edit">
                                                                <i class="feather-edit-3"></i>
                                                            </a>

                                                            <form id="delete-form-@table.Id"
                                                                  asp-controller="ServiceTables"
                                                                  asp-action="DeleteConfirmedAjax"
                                                                  asp-route-id="@table.Id"
                                                                  method="post"
                                                                  class="d-inline">
                                                                @Html.AntiForgeryToken()
                                                                <button type="button"
                                                                        class="btn btn-sm btn-light js-delete"
                                                                        data-id="@table.Id"
                                                                        title="Delete">
                                                                    <i class="feather-trash-2"></i>
                                                                </button>
                                                            </form>


                                                        </div>
                                                    </td>
                                                </tr>
                                            }
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>

@section Scripts {
    <script>
        $(document).ready(function () {

            if ($.fn.DataTable) {
                var table = $('.dataTable').DataTable();
            }

            setTimeout(function () {
                $('.alert-success').fadeOut('slow');
            }, 5000);

            $(document).on('click', '.js-delete', function (e) {
                e.preventDefault();

                var id = $(this).data('id');
                var form = $('#delete-form-' + id);
                var row = $(this).closest('tr');
                var token = form.find('input[name="__RequestVerificationToken"]').val();

                Swal.fire({
                    title: 'Are you sure?',
                    text: 'This table will be permanently deleted!',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#d33',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: 'Yes, delete it!',
                    cancelButtonText: 'Cancel'
                }).then((result) => {
                    if (result.isConfirmed) {
                        $.ajax({
                            url: form.attr('action'),
                            type: 'POST',
                            data: {
                                __RequestVerificationToken: token
                            },
                            success: function (response) {
                                if (response.success) {
                                    Swal.fire('Deleted!', response.message, 'success');
                                    // Remove row from DataTable
                                    if ($.fn.DataTable) {
                                        table.row(row).remove().draw();
                                    } else {
                                        row.remove();
                                    }
                                } else {
                                    Swal.fire('Error!', response.message, 'error');
                                }
                            },
                            error: function () {
                                Swal.fire('Error!', 'Something went wrong!', 'error');
                            }
                        });
                    }
                });
            });

        });
    </script>
}

