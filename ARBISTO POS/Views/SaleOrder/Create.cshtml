<script>
        /* ===============================
           HOLD ORDER FUNCTIONALITY
        =============================== */
        document.getElementById('holdOrderBtn').addEventListener('click', async function() {
            if (currentOrder.length === 0) {
                   toastr.error('Please add items to order first!', 'Validation Error'); // ✅ Toaster
                return;
            }

            // Show loading state
            const holdBtn = this;
            const originalText = holdBtn.innerHTML;
            holdBtn.innerHTML = 'Hold';
            holdBtn.disabled = true;

            // Prepare hold order data
            const holdData = {
                OrderNumber: null, // Will be generated server-side
                OrderType: document.getElementById('OrderTypeHidden').value,
                CustomerId: document.getElementById('CustomerId').value || null,
                TableId: document.getElementById('TableIdHidden').value || null,
                PickUpId: document.getElementById('Order_PickUpId').value || null,
                DelivaryAddress: document.getElementById('ShippingAddressHidden').value || null,
                PaymentId: null,
                PaymentStatus: "Unpaid",
                SubTotal: parseFloat(document.getElementById('SubTotalHidden').value) || 0,
                TaxAmount: parseFloat(document.getElementById('TaxHidden').value) || 0,
                DiscountAmount: parseFloat(document.getElementById('DiscountHidden').value) || 0,
                GrandTotal: parseFloat(document.getElementById('GrandTotalHidden').value) || 0,
                Items: currentOrder.map(item => ({
                    ItemId: item.id,
                    ItemName: item.name,
                    Price: item.price,
                    Quantity: item.qty,
                    ItemImage: item.image,
                    Total: item.price * item.qty
                }))
            };

            try {
                // Send hold request
                const response = await fetch('@Url.Action("HoldOrder", "SaleOrder")', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                    },
                    body: JSON.stringify(holdData)
                });

                const result = await response.json();

                if (result.success) {
                    // Show success message
                    toastr.success(`Order held successfully!`, 'Success'); // ✅ Toaster

                    // Reset current order
                    currentOrder.length = 0;
                    renderOrder();

                    // Update held orders count
                    await updateHeldOrdersCount();

                    // Reset form fields
                    resetForm();
                } else {
                    // alert('Failed to hold order: ' + result.message);
                          toastr.error('Failed to hold order:', 'Error'+ result.message); // ✅ Toaster
                }
            } catch (error) {
                console.error('Error holding order:', error);
                // alert('An error occurred while holding the order.');
                   toastr.error('An error occurred while holding the order.', 'Error'); // ✅ Toaster

            } finally {
                // Reset button
                holdBtn.innerHTML = originalText;
                holdBtn.disabled = false;
            }
        });

        /* ===============================
           UPDATE HELD ORDERS COUNT
        =============================== */
        async function updateHeldOrdersCount() {
            try {
                const response = await fetch('@Url.Action("GetHeldOrdersCount", "SaleOrder")');
                const data = await response.json();
                document.getElementById('heldCount').innerText = data.count;
            } catch (error) {
                console.error('Error updating held count:', error);
            }
        }

        /* ===============================
           LOAD HELD ORDERS IN MODAL
        =============================== */
        document.getElementById('openHeldModal').addEventListener('click', async function() {
            try {
                const response = await fetch('@Url.Action("GetHeldOrders", "SaleOrder")');
                const content = await response.text();
                document.querySelector('#heldInvoicesModal .modal-body').innerHTML = content;

                // Update count after modal opens
                await updateHeldOrdersCount();
            } catch (error) {
                console.error('Error loading held orders:', error);
                document.querySelector('#heldInvoicesModal .modal-body').innerHTML =
                    '<div class="alert alert-danger">Failed to load held orders</div>';
            }
        });
     /* ===============================
           LOAD HELD ORDER - COMPLETE FIX
        =============================== */
        async function loadHeldOrder(orderId) {
            try {
                console.log('Loading order:', orderId); // Debug log

                const response = await fetch(`/SaleOrder/LoadHeldOrder/${orderId}`);
                const result = await response.json();

                console.log('Server response:', result); // Debug log

                if (result.success) {
                    const order = result.order;

                    // ✅ CLEAR EVERYTHING FIRST
                    currentOrder.length = 0;
                    $('.select2-ajax-category').val(null).trigger('change');
                    $('.select2-ajax-Pickup').val(null).trigger('change');
                    document.getElementById('TableIdHidden').value = '';
                    document.getElementById('selectedTableText').innerText = 'Select Table';

                    // ✅ WAIT A BIT FOR CLEAR
                    await new Promise(resolve => setTimeout(resolve, 100));

                    // ✅ LOAD ITEMS FIRST
                    if (order.items && order.items.length > 0) {
                        console.log('Loading items:', order.items); // Debug log

                        order.items.forEach(item => {
                            currentOrder.push({
                                id: item.id,
                                name: item.name,
                                price: parseFloat(item.price),
                                qty: parseInt(item.qty),
                                image: item.image || '/assets/images/upload.jpg'
                            });
                        });

                        console.log('Current order after load:', currentOrder); // Debug log
                    }

                    // ✅ SET CUSTOMER
                    if (order.customerId) {
                        const customerOption = new Option(order.customerName, order.customerId, true, true);
                        $('.select2-ajax-category').empty().append(customerOption).trigger('change');
                        document.getElementById('CustomerId').value = order.customerId;
                    }

                    // ✅ SET ORDER TYPE
                    document.getElementById('orderTypeSelect').value = order.orderType;
                    document.getElementById('OrderTypeHidden').value = order.orderType;

                    // ✅ TRIGGER ORDER TYPE CHANGE
                    const changeEvent = new Event('change');
                    document.getElementById('orderTypeSelect').dispatchEvent(changeEvent);

                    // ✅ WAIT FOR UI UPDATE
                    await new Promise(resolve => setTimeout(resolve, 100));

                    // ✅ SHOW CORRECT FIELDS BASED ON ORDER TYPE
                    hideAllOrderInputs();

                    if (order.orderType === 'DINE IN') {
                        tableDiv.classList.remove('d-none');
                        if (order.tableId) {
                            document.getElementById('TableIdHidden').value = order.tableId;
                            document.getElementById('selectedTableText').innerText = order.tableName || 'Table Selected';
                        }
                    }
                    else if (order.orderType === 'PICKUP POINT') {
                        pickupDiv.classList.remove('d-none');
                        if (order.pickUpId) {
                            const pickupOption = new Option('Pickup Point', order.pickUpId, true, true);
                            $('.select2-ajax-Pickup').empty().append(pickupOption).trigger('change');
                        }
                    }
                    else if (order.orderType === 'DELIVERY') {
                        deliveryDiv.classList.remove('d-none');
                        if (order.deliveryAddress) {
                            document.getElementById('deliveryAddressInput').value = order.deliveryAddress.substring(0, 20) + '...';
                            document.getElementById('ShippingAddressHidden').value = order.deliveryAddress;
                        }
                    }

                    // ✅ SET DISCOUNT AND TAX
                    document.getElementById('DiscountHidden').value = order.discountAmount || 0;
                    document.getElementById('TaxHidden').value = order.taxAmount || 0;
                    document.getElementById('discountInput').value = order.discountAmount || 0;
                    document.getElementById('taxInput').value = order.taxAmount || 0;

                    // ✅ RENDER ORDER (THIS IS THE KEY)
                    console.log('Rendering order...'); // Debug log
                    renderOrder();

                    // ✅ FORCE RECALCULATE TOTALS
                    calculateGrandTotal();

                    // ✅ CLOSE MODAL
                    const modal = bootstrap.Modal.getInstance(document.getElementById('heldInvoicesModal'));
                    if (modal) {
                        modal.hide();
                    }

                    // ✅ DELETE FROM DATABASE
                    await deleteHeldOrderAfterLoad(orderId);

                    // alert('Order loaded successfully!');
                          toastr.success(`Order Restored successfully!`, 'Success'); // ✅ Toaster
                } else {
                    // alert('Failed to load order: ' + result.message);
                       toastr.error('Failed to load order:', 'Error'+ result.message); // ✅ Toaster

                }
            } catch (error) {
                console.error('Error loading order:', error);
                // alert('An error occurred: ' + error.message);
                toastr.error('An error occurred:', 'Error'+ result.message); // ✅ Toaster

            }
        }



        /* ===============================
           DELETE HELD ORDER AFTER LOADING
        =============================== */
        async function deleteHeldOrderAfterLoad(orderId) {
            try {
                const response = await fetch(`/SaleOrder/DeleteHeldOrder/${orderId}`, {
                    method: 'POST',
                    headers: {
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                    }
                });

                if (response.ok) {
                    await updateHeldOrdersCount();
                }
            } catch (error) {
                console.error('Error deleting held order:', error);
            }
        }

        /* ===============================
           DELETE HELD ORDER
        =============================== */
        async function deleteHeldOrder(orderId) {
            if (!confirm('Are you sure you want to delete this held order?')) {
                return;
            }

            try {
                const response = await fetch(`/SaleOrder/DeleteHeldOrder/${orderId}`, {
                    method: 'POST',
                    headers: {
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                    }
                });

                const result = await response.json();

                if (result.success) {
                    alert('Order deleted successfully!');

                    // Reload held orders list
                    await loadHeldOrdersList();

                    // Update count
                    await updateHeldOrdersCount();
                } else {
                    alert('Failed to delete order: ' + result.message);
                }
            } catch (error) {
                console.error('Error deleting order:', error);
                alert('An error occurred while deleting the order.');
            }
        }

        /* ===============================
           RELOAD HELD ORDERS LIST IN MODAL
        =============================== */
        async function loadHeldOrdersList() {
            try {
                const response = await fetch('@Url.Action("GetHeldOrders", "SaleOrder")');
                const html = await response.text();
                document.querySelector('#heldInvoicesModal .modal-body').innerHTML = html;
            } catch (error) {
                console.error('Error loading held orders:', error);
            }
        }

        /* ===============================
           RESET FORM
        =============================== */
        function resetForm() {
            // Reset order type to default
            document.getElementById('orderTypeSelect').value = 'DINE IN';
            document.getElementById('OrderTypeHidden').value = 'DINE IN';

            // Hide all order inputs and show Dine In
            hideAllOrderInputs();
            tableDiv.classList.remove('d-none');

            // Reset customer
            $('.select2-ajax-category').val(null).trigger('change');

            // Reset table
            document.getElementById('TableIdHidden').value = '';
            document.getElementById('selectedTableText').innerText = 'Select Table';

            // Reset pickup
            $('.select2-ajax-Pickup').val(null).trigger('change');

            // Reset delivery
            document.getElementById('deliveryAddressInput').value = '';
            document.getElementById('ShippingAddressHidden').value = '';

            // Reset totals
            document.getElementById('DiscountHidden').value = 0;
            document.getElementById('TaxHidden').value = 0;
            document.getElementById('discountInput').value = '';
            document.getElementById('taxInput').value = '';
        }

        /* ===============================
           TRUNCATE ADDRESS FUNCTION
        =============================== */
        function truncateAddress(text, maxLength) {
            if (!text) return '';
            text = text.trim();
            if (text.length <= maxLength) {
                return text;
            }
            return text.substring(0, maxLength) + '...';
        }

        // Load held orders count on page load
        document.addEventListener('DOMContentLoaded', function() {
            updateHeldOrdersCount();
        });

    </script>
