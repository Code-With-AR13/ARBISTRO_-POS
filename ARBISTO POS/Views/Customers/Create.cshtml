@model ARBISTO_POS.Models.Customers

@{
    ViewData["Title"] = "Create Customers";
}

<div class="page-header">
    <div class="page-header-left d-flex align-items-center">
        <ul class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li class="breadcrumb-item"><a asp-controller="Customers" asp-action="Index">Customers</a></li>
            <li class="breadcrumb-item active">Create</li>
        </ul>
    </div>
    <div class="page-header-right ms-auto">
        <div class="d-flex align-items-center gap-2 page-header-right-items-wrapper">
            <a asp-controller="Customers" asp-action="Index" class="btn btn-primary">
                <i class="feather-arrow-left me-2"></i>
                <span>Back To Customers</span>
            </a>
        </div>
    </div>
</div>

<div class="main-content">
    <div class="row">
        <div class="col-lg-12">
            <div class="card border-top-0">
                <div class="card-header">
                    <h5 class="card-title">
                        <i class="feather-plus-circle me-2"></i>Create New Customers
                    </h5>
                </div>

                <div class="card-body">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <form asp-action="Create"
                          asp-controller="Customers"
                          method="post"
                          enctype="multipart/form-data"
                          id="ingredientForm">
                        <div class="row">
                            <div class="col-lg-4 mb-4">
                                <div class="card bg-light">
                                    <div class="card-body text-center">
                                        <label class="form-label fw-semibold">Customers Image</label>

                                        <div class="position-relative mx-auto" style="width: 200px; height: 200px;">
                                            <div class="border border-2 border-dashed rounded-3 overflow-hidden h-100 w-100 position-relative bg-white"
                                                 id="avatarDiv"
                                                 style="cursor: pointer;">
                                                <img id="avatarPreview"
                                                     src="~/assets/images/upload.jpg"
                                                     class="img-fluid h-100 w-100"
                                                     style="object-fit: cover;"
                                                     alt="Upload Image">
                                                <div class="position-absolute start-0 top-0 w-100 h-100 d-flex align-items-center justify-content-center bg-dark bg-opacity-50"
                                                     id="uploadOverlay"
                                                     style="opacity: 0; transition: opacity 0.3s;">
                                                    <i class="feather-camera text-white" style="font-size: 32px;"></i>
                                                </div>
                                            </div>
                                            <input type="file"
                                                   accept="image/png,image/jpg,image/jpeg"
                                                   asp-for="ImageFile"
                                                   id="fileInput"
                                                   style="display: none;" />
                                        </div>

                                        <div class="mt-3">
                                            <small class="text-muted d-block"><i class="feather-info me-1"></i>Click image to upload</small>
                                            <small class="text-muted d-block">Size: 150x150px (Max 2MB)</small>
                                            <small class="text-muted d-block">Format: PNG, JPG, JPEG</small>
                                        </div>
                                        <span asp-validation-for="ImageFile" class="text-danger small"></span>
                                    </div>
                                </div>
                            </div>

                            <div class="col-lg-8">
                                <div class="mb-3">
                                    <label asp-for="Name" class="form-label fw-semibold">Name <span class="text-danger">*</span></label>
                                    <input asp-for="Name" class="form-control" placeholder="Customers name" />
                                    <span asp-validation-for="Name" class="text-danger small"></span>
                                </div>

                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label asp-for="Email" class="form-label fw-semibold">Email</label>
                                        <input asp-for="Email" class="form-control" placeholder="Customer@Example.com" />
                                        @* <span asp-validation-for="Email" class="text-danger small"></span> *@
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label asp-for="PhoneNo" class="form-label fw-semibold">Phone No</label>
                                        <input asp-for="PhoneNo" class="form-control" placeholder="+924358974323"  />
                                        @* <span asp-validation-for="PhoneNo" class="text-danger small"></span> *@
                                    </div>                                    
                                </div>   
                                <div class="col-md-12 mb-3">
                                    <label asp-for="Address" class="form-label fw-semibold">Address</label>
                                    <input asp-for="Address" class="form-control" placeholder="Street No Mohala etc..." />
                                    @* <span asp-validation-for="Unit" class="text-danger small"></span> *@
                                </div>

                                <div class="d-flex gap-2 justify-content-end mt-4">
                                    <a asp-action="Index" class="btn btn-light">
                                        <i class="feather-x me-1"></i>Cancel
                                    </a>
                                    <button type="submit" class="btn btn-primary">
                                        <i class="feather-save me-1"></i>Save Customers
                                    </button>
                                </div>
                            </div>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @* <partial name="_ValidationScriptsPartial" /> *@

    <script>
        $(document).ready(function () {
            const avatarDiv = $('#avatarDiv');
            const fileInput = $('#fileInput');
            const avatarPreview = $('#avatarPreview');
            const uploadOverlay = $('#uploadOverlay');

            avatarDiv.on('click', function () { fileInput.click(); });

            avatarDiv.on('mouseenter', function () {
                uploadOverlay.css('opacity', '1');
            }).on('mouseleave', function () {
                uploadOverlay.css('opacity', '0');
            });

            fileInput.on('change', function (e) {
                const file = e.target.files[0];

                if (file) {
                    if (file.size > 2 * 1024 * 1024) {
                        alert('File size must be less than 2MB');
                        fileInput.val('');
                        return;
                    }

                    const validTypes = ['image/png', 'image/jpg', 'image/jpeg'];
                    if (!validTypes.includes(file.type)) {
                        alert('Only PNG, JPG, and JPEG files are allowed');
                        fileInput.val('');
                        return;
                    }

                    const reader = new FileReader();
                    reader.onload = function (event) {
                        avatarPreview.attr('src', event.target.result);
                        avatarDiv.addClass('border-success');
                        setTimeout(() => { avatarDiv.removeClass('border-success'); }, 1000);
                    };
                    reader.readAsDataURL(file);
                }
            });
        });
    </script>
}
