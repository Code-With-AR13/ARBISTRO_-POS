@model ARBISTO_POS.ViewModels.ForgotPasswordViewModel
@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Forgot Password";
}

<main class="auth-creative-wrapper">
    <div class="auth-creative-inner">
        <div class="creative-card-wrapper">
            <div class="card my-4 overflow-hidden" style="z-index: 1">
                <div class="creative-card-body card-body p-sm-5">
                    <h2 class="fs-20 fw-bolder mb-4">Forgot Password</h2>
                    <p class="fs-12 fw-medium text-muted">
                         Please enter your registered email address. We will send you a password reset link.
                    </p>

                    <form asp-action="ForgotPassword" method="post" class="w-100 mt-4">
                        @Html.AntiForgeryToken()

                        <div class="mb-4">
                            <input name="Email"
                                   type="email"
                                   class="form-control"
                                   placeholder="Email Address"
                                   required />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <div class="mt-4">
                            <button type="submit" class="btn btn-lg btn-primary w-100">
                                Send Reset Link
                            </button>
                        </div>
                    </form>

                    <div class="mt-4 text-center">
                        <a asp-action="Login" class="fs-12 text-primary">
                            ← Back to Login
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>
