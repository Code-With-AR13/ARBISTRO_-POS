@model IEnumerable<ARBISTO_POS.Models.Modifier>

@{
    ViewData["Title"] = "Modifiers";
}
<main class="nxl-container-fluid">
    <div class="nxl-content">
        <!-- Page Header -->
        <div class="page-header">
            <div class="page-header-left d-flex align-items-center">
                <div class="page-header-title">
                    <h5 class="m-b-10">@ViewData["Title"]</h5>
                </div>
                <ul class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
                    <li class="breadcrumb-item active">@ViewData["Title"]</li>
                </ul>
            </div>
            <div class="page-header-right ms-auto">
                <div class="d-flex align-items-center gap-2 page-header-right-items-wrapper">
                    <a asp-controller="Modifier" asp-action="Create" class="btn btn-primary">
                        <i class="feather-plus me-2"></i>
                        <span>New Modifier</span>
                    </a>
                </div>
            </div>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="feather-check-circle me-2"></i>
                <strong>Success!</strong> @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <div class="main-content">
            <div class="row">
                <div class="col-lg-12">
                    <div class="card stretch stretch-full">
                        <div class="card-header">
                            <h5 class="card-title mb-0">
                                <i class="feather-shopping-bag me-2"></i>All Modifier
                            </h5>
                        </div>
                        <div class="card-body p-0">
                            <div class="table-responsive">
                                <table class="table table-hover align-middle dataTable">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Modifier</th>                                            
                                            <th>Ingredient</th>
                                            <th>Discription</th>
                                            <th>Cost</th>
                                            <th>Price</th>
                                            <th class="text-center" style="width: 120px;">Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (Model != null && Model.Any())
                                        {
                                            @foreach (var item in Model)
                                            {
                                                <tr>
                                                    <td>
                                                        <div class="d-flex align-items-center">
                                                            <div class="me-3">
                                                                @if (!string.IsNullOrEmpty(item.ModeImage))
                                                                {
                                                                    <img src="@item.ModeImage"
                                                                         alt="@item.ModeName"
                                                                         class="rounded-circle border"
                                                                         style="width: 80px; height: 80px; object-fit: cover;"
                                                                         onerror="this.src='/assets/images/upload.jpg'">
                                                                }
                                                                else
                                                                {
                                                                    <img src="~/assets/images/upload.jpg"
                                                                         alt="No Image"
                                                                         class="rounded-circle border"
                                                                         style="width: 80px; height: 80px; object-fit: cover;">
                                                                }
                                                            </div>
                                                            <div class="d-flex flex-column">
                                                                <span class="fw-semibold">@item.ModeName</span>
                                                                @if (!string.IsNullOrEmpty(item.ModeDiscription))
                                                                {
                                                                    <span class="text-muted small">@item.ModeDiscription.Substring(0, Math.Min(50, item.ModeDiscription.Length))@(item.ModeDiscription.Length > 50 ? "..." : "")</span>
                                                                }
                                                            </div>
                                                        </div>
                                                    </td>                                                   
                                                    <td>
                                                        @if (item.ModifierIngredients != null && item.ModifierIngredients.Any())
                                                        {
                                                @string.Join(", ", item.ModifierIngredients
                                                                                                .Select(ii => ii.Ingredient.Name))
                                                                                                }

                                                    </td>
                                                    <td>
                                                        <span>@item.ModeDiscription</span>
                                                    </td>
                                                    <td>
                                                        <span class="text-muted">@item.ItemCost.00</span>
                                                    </td>
                                                    <td>
                                                        <strong>@item.ItemPrice.00</strong>
                                                    </td>
                                                    <td class="text-center">
                                                        <div class="d-inline-flex gap-1">
                                                            <a asp-action="Edit"
                                                               asp-route-id="@item.ItemId"
                                                               class="btn btn-sm btn-light"
                                                               title="Edit">
                                                                <i class="feather-edit-3"></i>
                                                            </a>

                                                            <!-- unique id per form -->
                                                            <form id="delete-form-@item.ItemId"
                                                                  asp-controller="Modifier"
                                                                  asp-action="Delete"
                                                                  asp-route-id="@item.ItemId"
                                                                  method="post"
                                                                  class="d-inline">
                                                                @Html.AntiForgeryToken()
                                                                <button type="button"
                                                                        class="btn btn-sm btn-light js-delete"
                                                                        data-id="@item.ItemId"
                                                                        title="Delete">
                                                                    <i class="feather feather-trash-2"></i>
                                                                </button>
                                                            </form>
                                                        </div>
                                                    </td>
                                                </tr>
                                            }
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('.dataTable').DataTable();

            // hide success alert
            setTimeout(function () {
                $('.alert-success').fadeOut('slow');
            }, 5000);

            // tooltips
            var tooltipTriggerList = [].slice.call(document.querySelectorAll('[title]'));
            tooltipTriggerList.map(function (el) { return new bootstrap.Tooltip(el); });

            // SweetAlert delete
            $('.js-delete').on('click', function (e) {
                e.preventDefault();

                const id = $(this).data('id');
                const form = $('#delete-form-' + id);

                Swal.fire({
                    title: 'Are you sure?',
                    text: 'This item will be permanently deleted.',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#d33',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: 'Yes, delete it',
                    cancelButtonText: 'Cancel'
                }).then((result) => {
                    if (result.isConfirmed) {
                        form.submit();   // POST /Items/Delete/{id}
                    }
                });
            });
        });
    </script>
}
