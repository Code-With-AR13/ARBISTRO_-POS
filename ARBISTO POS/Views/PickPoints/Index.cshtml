@model IEnumerable<ARBISTO_POS.Models.PickPoints>

@{
    ViewData["Title"] = "Pick Points";
}

<main class="nxl-container-fluid">
    <div class="nxl-content">
        <!-- Page Header -->
        <div class="page-header">
            <div class="page-header-left d-flex align-items-center">
                <div class="page-header-title">
                    <h5 class="m-b-10">Pick Points</h5>
                </div>
                <ul class="breadcrumb">
                    <li class="breadcrumb-item">
                        <a asp-controller="Home" asp-action="Index">Home</a>
                    </li>
                    <li class="breadcrumb-item active">Pick Points</li>
                </ul>
            </div>
            <div class="page-header-right ms-auto">
                <div class="d-flex align-items-center gap-2 page-header-right-items-wrapper">
                    <a asp-controller="PickPoints" asp-action="Create" class="btn btn-primary">
                        <i class="feather-plus me-2"></i>
                        <span>New Pick Point</span>
                    </a>
                </div>
            </div>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                <i class="feather-check-circle me-2"></i>
                <strong>Success!</strong> @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <div class="main-content">
            <div class="row">
                <div class="col-lg-12">
                    <div class="card stretch stretch-full">
                        <div class="card-header">
                            <h5 class="card-title mb-0">
                                <i class="feather-list me-2"></i>All Pick Points
                            </h5>
                        </div>

                        <div class="card-body p-0">
                            <div class="table-responsive">
                                <table class="table table-hover align-middle dataTable" id="pickTable">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Pick Point</th>
                                            <th>Person Name</th>
                                            <th>Phone No</th>
                                            <th>Address</th>
                                            <th>Description</th>
                                            <th class="text-center" style="width:120px;">Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @* AJAX DATA WILL LOAD HERE *@
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>

@section Scripts {
    <script>
        $(document).ready(function () {

            var table = $('#pickTable').DataTable({
                
                "serverSide": false,
                "ajax": {
                    "url": "/PickPoints/GetAll", // ⚠️ backend required
                    "type": "GET",
                    "dataSrc": ""
                },
                "columns": [
                    {
                        "data": null,
                        "render": function (data) {
                            return `
                                <div class="d-flex flex-column">
                                    <span class="fw-semibold">${data.picTittle}</span>
                                    <small class="text-muted">Created At: ${data.createdDate}</small>
                                </div>`;
                        }
                    },
                    { "data": "personName" },
                    { "data": "phoneNo" },
                    { "data": "address" },
                    {
                        "data": "picDescription",
                        "render": function (data) {
                            if (!data)
                                return '<span class="text-muted fst-italic">No description</span>';

                            return data.length > 80 ? data.substring(0, 80) + "..." : data;
                        }
                    },
                    {
                        "data": null,
                        "orderable": false,
                        "className": "text-center",
                        "render": function (data) {
                            return `
                                <div class="d-inline-flex gap-1">
                                    <a href="/PickPoints/Edit/${data.id}"
                                       class="btn btn-sm btn-light">
                                        <i class="feather-edit-3"></i>
                                    </a>

                                    <form id="delete-form-${data.id}"
                                          action="/PickPoints/DeleteConfirmed"
                                          method="post"
                                          class="d-none">
                                        <input name="__RequestVerificationToken"
                                               value="${$('input[name="__RequestVerificationToken"]').val()}" />
                                        <input type="hidden" name="id" value="${data.id}" />
                                    </form>

                                    <button class="btn btn-sm btn-light js-delete"
                                            data-id="${data.id}">
                                        <i class="feather-trash-2"></i>
                                    </button>
                                </div>`;
                        }
                    }
                ]
            });

            // DELETE (AJAX)
            $(document).on('click', '.js-delete', function (e) {
                e.preventDefault();

                const id = $(this).data('id');
                const form = $('#delete-form-' + id);
                const token = $('input[name="__RequestVerificationToken"]').val();

                Swal.fire({
                    title: 'Are you sure?',
                    text: 'This pick point will be permanently deleted!',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#d33',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: 'Yes, delete it!'
                }).then((result) => {
                    if (result.isConfirmed) {
                        $.ajax({
                            url: form.attr('action'),
                            type: 'POST',
                            data: { id: id, __RequestVerificationToken: token },
                            success: function (res) {
                                if (res.success) {
                                    table.ajax.reload(); // ✅ reload via AJAX
                                    Swal.fire('Deleted!', res.message, 'success');
                                } else {
                                    Swal.fire('Error', res.message, 'error');
                                }
                            }
                        });
                    }
                });
            });

            setTimeout(() => $('.alert-success').fadeOut('slow'), 5000);
        });
    </script>
}