// Attach click events to menu items
function attachItemClickEvents() {
    $('.menu-item-card').off('click').on('click', function() {
        const id = $(this).data('item-id');
        const name = $(this).data('item-name');
        const price = parseFloat($(this).data('item-price'));
        const image = $(this).data('item-image') || '/assets/images/upload.jpg';

        const existing = currentOrder.find(i => i.id === id);
        if (existing) {
