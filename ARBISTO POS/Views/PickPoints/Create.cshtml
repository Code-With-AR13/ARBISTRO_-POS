@model ARBISTO_POS.Models.PickPoints

@{
    ViewData["Title"] = "Create Pick Point";
}

<!-- [ page-header ] start -->
<div class="page-header">
    <div class="page-header-left d-flex align-items-center">
        <ul class="breadcrumb">
            <li class="breadcrumb-item">
                <a asp-controller="Home" asp-action="Index">Home</a>
            </li>
            <li class="breadcrumb-item">
                <a asp-controller="PickPoints" asp-action="Index">Pick Points</a>
            </li>
            <li class="breadcrumb-item active">Create</li>
        </ul>
    </div>
    <div class="page-header-right ms-auto">
        <div class="d-flex align-items-center gap-2 page-header-right-items-wrapper">
            <a asp-controller="PickPoints" asp-action="Index" class="btn btn-primary">
                <i class="feather-arrow-left me-2"></i>
                <span>Back To Pick Points</span>
            </a>
        </div>
    </div>
</div>
<!-- [ page-header ] end -->
<!-- [ Main Content ] start -->
<div class="main-content">
    <div class="row">
        <div class="col-lg-12">
            <div class="card border-top-0">
                <div class="card-header">
                    <h5 class="card-title">
                        <i class="feather-plus-circle me-2"></i>Create New Pick Point
                    </h5>
                </div>

                <div class="card-body">

                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show">
                            <i class="feather-check-circle me-2"></i>@TempData["SuccessMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <form method="post">
                        <div class="row">

                            <!-- LEFT COLUMN (Empty for layout consistency) -->
                            <div class="col-lg-4 mb-4">
                                <div class="card bg-light">
                                    <div class="card-body text-center">
                                        <span class="text-muted">No image required for Pick Points</span>
                                    </div>
                                </div>
                            </div>

                            <!-- RIGHT COLUMN -->
                            <div class="col-lg-8">

                                <!-- PICK POINT TITLE -->
                                <div class="mb-3">
                                    <label asp-for="PicTittle" class="form-label fw-semibold">
                                        Pick Point Name <span class="text-danger">*</span>
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text">
                                            <i class="feather-tag"></i>
                                        </span>
                                        <input asp-for="PicTittle"
                                               class="form-control"
                                               placeholder="e.g. Main Office, Warehouse" />
                                    </div>
                                    <span asp-validation-for="PicTittle" class="text-danger small"></span>
                                </div>

                                <!-- DESCRIPTION -->
                                <div class="mb-3">
                                    <label asp-for="PicDescription" class="form-label fw-semibold">
                                        Description
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text">
                                            <i class="feather-file-text"></i>
                                        </span>
                                        <textarea asp-for="PicDescription"
                                                  class="form-control"
                                                  placeholder="Optional description..."></textarea>
                                    </div>
                                </div>

                                <!-- PERSON NAME -->
                                <div class="mb-3">
                                    <label asp-for="PersonName" class="form-label fw-semibold">
                                        Person Name
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text">
                                            <i class="feather-user"></i>
                                        </span>
                                        <input asp-for="PersonName" class="form-control" placeholder="Contact person name" />
                                    </div>
                                </div>

                                <!-- PHONE NUMBER -->
                                <div class="mb-3">
                                    <label asp-for="PhoneNo" class="form-label fw-semibold">
                                        Phone Number
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text">
                                            <i class="feather-phone"></i>
                                        </span>
                                        <input asp-for="PhoneNo" class="form-control" placeholder="Contact number" />
                                    </div>
                                </div>

                                <!-- ADDRESS -->
                                <div class="mb-3">
                                    <label asp-for="Address" class="form-label fw-semibold">
                                        Address
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text">
                                            <i class="feather-map-pin"></i>
                                        </span>
                                        <textarea asp-for="Address" class="form-control" placeholder="Optional address"></textarea>
                                    </div>
                                </div>

                                <!-- ACTIONS -->
                                <div class="d-flex gap-2 justify-content-end mt-4">
                                    <a asp-action="Index" class="btn btn-light">
                                        <i class="feather-x me-1"></i>Cancel
                                    </a>
                                    <button type="submit" class="btn btn-primary">
                                        <i class="feather-save me-1"></i>Save Pick Point
                                    </button>
                                </div>

                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- [ Main Content ] end -->
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
