@using ARBISTO_POS.ViewModels
@model PosViewModel

@{
    ViewData["Title"] = "Edit Order";
    Layout = "_POSLayout";
}

<style>
    .card-hover {
        transition: transform 0.3s, box-shadow 0.3s;
        transform-style: preserve-3d;
        cursor: pointer;
    }

        .card-hover:hover {
            transform: scale(1.05);
            box-shadow: 0 15px 30px rgba(0, 0, 0, 0.3);
            z-index: 10;
        }
    /* Blink animation */
    @@keyframes blink-animation {
        0% {
            opacity: 1;
        }

        50% {
            opacity: 0.5;
        }

        100% {
            opacity: 1;
        }
    }

    .blink {
        animation: blink-animation 3s infinite;
    }
</style>

<!------------------------------------------------------------------------ NAVBAR --------------------------------------------------------------->
<nav class="navbar navbar-expand-lg navbar-dark bg-white shadow-sm">
    <div class="container-fluid">
        <a class="navbar-brand ps-4" href="#">
            <img src="~/assets/images/LOGO-Name.png" alt="Logo" class="b-brand" style="max-height:40px;" />
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>
        
        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav ms-auto align-items-center gap-3 pe-3">
                <li class="nav-item d-flex align-items-center gap-2 border-primary">
                    <select asp-for="Order.OrderType" class="form-select border border-primary form-select-sm" style="width:150px;" id="orderTypeSelect">
                        <option id="dineInBtn" value="DINE IN">DINE IN</option>
                        <option id="pickupBtn" value="PICKUP POINT">PICKUP POINT</option>
                        <option id="deliveryBtn" value="DELIVERY">DELIVERY</option>
                    </select>
                </li>

                <!-- 🔥 PAYMENT BUTTON (In Progress ki jagah) -->
                <li class="nav-item">
                    <button type="button" class="btn btn-success px-3 py-2 fs-6 blink" data-bs-toggle="modal" data-bs-target="#paymentModal">
                        <i class="feather-dollar-sign"></i> Payment
                    </button>
                </li>                    

                <li class="nav-item d-none d-sm-flex">
                    <div class="full-screen-switcher">
                        <a href="javascript:void(0);" class="btn btn-dark px-3 py-2 position-relative" onclick="$('body').fullScreenHelper('toggle');">
                            <i class="feather-maximize maximize"></i>
                            <i class="feather-minimize minimize"></i>
                        </a>
                    </div>
                </li>

                <!-- Button to Open Modal -->
                <li class="nav-item position-relative">
                    <button type="button" id="openHeldModal" class="btn btn-danger px-3 py-2 position-relative"
                            data-bs-toggle="modal" data-bs-target="#heldInvoicesModal">
                        <i class="feather-list"></i>
                        <span id="heldCount" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-dark">
                            0
                        </span>
                    </button>
                </li>

                <li class="nav-item dropdown">
                    <a href="javascript:void(0);" data-bs-toggle="dropdown" role="button" class="d-flex align-items-center">
                        <img src="~/assets/images/logo-abbr (2).png" alt="user-image" class="rounded-circle" style="width:48px; height:48px; object-fit:cover;" />
                    </a>
                    @if (User?.Identity?.IsAuthenticated == true)
                    {
                        <div class="dropdown-menu dropdown-menu-end shadow">
                            <a class="dropdown-item" href="#"><i class="feather-user me-2"></i>Profile</a>
                            <a class="dropdown-item" href="#"><i class="feather-settings me-2"></i>Settings</a>
                            <a class="dropdown-item" asp-controller="Home" asp-action="Index"><i class="feather-arrow-left me-2"></i>Back to Dashboard</a>
                            <div class="dropdown-divider"></div>
                            <form asp-controller="Auth" asp-action="Logout" method="post" class="m-0">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="dropdown-item text-danger"><i class="feather-log-out me-2"></i>Logout</button>
                            </form>
                        </div>
                    }
                    else
                    {
                        <a class="dropdown-item" asp-controller="Auth" asp-action="Login"><i class="isax isax-login-1 me-2"></i>LogIn</a>
                    }
                </li>
            </ul>
        </div>       
    </div>
</nav>

<form asp-action="Edit" method="post" id="posForm">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Order.OrderId" />
    <input type="hidden" asp-for="Order.OrderNumber" />
    
<div class="d-flex" style="height: calc(100vh - 70px); overflow: hidden;">
    <!-- LEFT: Categories -->
    <div class="bg-white border-end p-3 d-flex flex-column flex-shrink-0"
         style="width: 200px; min-width:190px; max-width:190px; overflow-y:auto;">
        <h6 class="fw-bold mb-3">Categories</h6>
        <div class="flex-grow-1">
            @foreach (var cat in Model.Categories)
            {
                <a href="javascript:void(0);"
                   class="list-group-item list-group-item-action mb-2 d-flex flex-column align-items-center text-center category-filter @(cat == Model.Categories.First() ? "active" : "")"
                   data-category-id="@cat.Id">
                    <img src="@cat.CateImage" alt="@cat.CateName" class="img-fluid rounded mb-1" style="width:90%; height:140px; object-fit:cover;">
                    <span class="text-dark">@cat.CateName</span>
                </a>
            }
        </div>
    </div>

    <!---------------------------------------------------------- CENTER: MENU ITEMS ----------------------------------------------------------->
    <div class="flex-grow-1 p-4 bg-light overflow-auto d-flex flex-column">

        <!-- Search -->
        <div class="d-flex align-items-center justify-content-between mb-4">
            <input type="text" class="form-control me-2" placeholder="Search items..." id="itemSearch">
        </div>

        @if (Model.Items == null || !Model.Items.Any())
        {
            <!-- CENTER MESSAGE -->
            <div class="flex-grow-1 d-flex align-items-center justify-content-center text-center text-muted">
                <div>
                    <i class="bi bi-basket fs-1 mb-2 d-block"></i>
                    <div class="fw-semibold">No items Found For this Category</div>
                    <small>Select Another Category</small>
                </div>
            </div>
        }
        else
        {
            <!-- ITEMS GRID -->
            <div class="d-flex flex-wrap justify-content-start gap-2">
                @foreach (var p in Model.Items)
                {
                    <div class="d-flex justify-content-center menu-item" data-category="@p.FoodCategoryId">
                        <div class="card h-90 shadow-sm card-hover menu-item-card"
                             style="width: 140px; overflow: hidden;"
                             data-item-id="@p.ItemId"
                             data-item-name="@p.ItemName"
                             data-item-price="@p.ItemPrice"
                             data-item-image="@p.CateImage">

                            @if (!string.IsNullOrEmpty(p.CateImage))
                            {
                                <img src="@p.CateImage"
                                     alt="@p.ItemName"
                                     class="card-img-top w-100 img-hover-zoom"
                                     style="height:100px; object-fit:cover;"
                                     onerror="this.src='/assets/images/upload.jpg'">
                            }
                            else
                            {
                                <img src="~/assets/images/upload.jpg"
                                     alt="No Image"
                                     class="card-img-top w-100 img-hover-zoom"
                                     style="height:100px; object-fit:cover;">
                            }

                            <div class="card-body p-2 text-center">
                                <h6 class="card-title fw-bold mb-1 text-truncate">@p.ItemName</h6>
                                <p class="fw-bold text-danger mb-0">@p.ItemPrice.00</p>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }

    </div>

    <!------------------------------------------------------- RIGHT: ORDER PANEL -------------------------------------------------------------->
    <div class="bg-white border-start p-4 d-flex flex-column flex-shrink-0"
         style="width: 615px; min-width:615px; max-width:615px; overflow-y:auto;">       
            <div class="row g-2 mb-3">
                <!-- Customer -->
                <div class="col d-flex flex-column">
                    <label asp-for="CustomerId" class="form-label fw-semibold">Customers <span class="text-danger">*</span></label>
                    <select asp-for="CustomerId" class="form-select select2-ajax-category" style="width: 100%;">
                        @if (Model.Order.CustomerId > 0 && Model.Order.Customer != null)
                        {
                            <option value="@Model.Order.CustomerId" selected>@Model.Order.Customer.Name</option>
                        }
                        else
                        {
                            <option value="">Select Customer</option>
                        }
                    </select>
                    <span asp-validation-for="CustomerId" class="text-danger small"></span>
                </div>
                
                <!-- Hidden field for OrderType -->
                <input type="hidden" asp-for="Order.OrderType" id="OrderTypeHidden" value="@Model.Order.OrderType" />

            <!-- Dine In Table Button -->
            <div class="col d-flex flex-column order-type-input @(Model.Order.OrderType != "DINE IN" ? "d-none" : "")" id="tableSelectDiv">
                <label class="form-label small fw-semibold"><i class="bi bi-table"></i> Table</label>
                <button type="button" id="openTableModal" class="btn btn-outline-primary flex-grow-1 fs-6 py-1">
                    <div id="selectedTableText">@(Model.Order.Table != null ? Model.Order.Table.TabName : "Select Table")</div>
                </button>
                <input type="hidden" asp-for="Order.TableId" id="TableIdHidden" value="@Model.Order.TableId" />
            </div>

                <!-- Pickup Dropdown -->
                <div class="col d-flex flex-column order-type-input @(Model.Order.OrderType != "PICKUP POINT" ? "d-none" : "")" id="pickupSelectDiv">
                    <label class="form-label small fw-semibold"><i class="bi bi-bag"></i> Pickup Point</label>
                    <select asp-for="Order.PickUpId" class="form-select select2-ajax-Pickup" style="width: 100%;">
                        <option value="">Select Pickup Point(OPT)</option>
                    </select>
                </div>

            <!-- Delivery Input -->
            <div class="col d-flex flex-column order-type-input @(Model.Order.OrderType != "DELIVERY" ? "d-none" : "")" id="deliveryInputDiv">
                <label class="form-label small fw-semibold"><i class="bi bi-truck"></i> Shipping Address</label>
                <input type="text"
                       id="deliveryAddressInput"
                       class="form-control"
                       value="@(Model.Order.DelivaryAddress != null && Model.Order.DelivaryAddress.Length > 20 ? Model.Order.DelivaryAddress.Substring(0, 20) + "..." : Model.Order.DelivaryAddress)"
                       readonly
                       style="cursor: pointer; background-color: #fff;"
                       title="@Model.Order.DelivaryAddress">
                <input type="hidden" asp-for="Order.DelivaryAddress" id="ShippingAddressHidden" value="@Model.Order.DelivaryAddress" />
            </div>
         </div>

            <!-- Order Items -->
            <div class="flex-grow-1 overflow-auto mb-3 border rounded p-3 bg-light" id="orderList">
                <div class="text-center text-muted">
                    <i class="bi bi-basket fs-1 mb-2"></i>
                    <div class="fw-semibold">Loading items...</div>
                </div>
            </div>

            <!-- Totals -->
            <div class="d-flex justify-content-between mb-1">
                <span>Subtotal</span>
            <input type="hidden" asp-for="Order.SubTotal" id="SubTotalHidden" value="@Model.Order.SubTotal" />            
                <span id="subtotal">@Model.Order.SubTotal.ToString("F2")</span>
            </div>

        <!-- Tax -->
        <div class="d-flex justify-content-between mb-1">
            <span>
                Tax
                <button id="openTaxModal"
                        type="button"
                        class="border-0 bg-transparent p-0 ms-1 text-muted">
                    <i class="feather-edit-3"></i>
                </button>
            </span>
            <span id="tax">@Model.Order.TaxAmount.ToString("F2")</span>
        </div>

            <!-- Discount -->
        <div class="d-flex justify-content-between mb-1">
            <span>
                Discount
                <button type="button"
                        id="openDiscountModal"
                        class="border-0 bg-transparent p-0 ms-1 text-muted">
                    <i class="feather-edit-3"></i>
                </button>
            </span>
            <span id="discount">@Model.Order.DiscountAmount.ToString("F2")</span>
        </div>

            <!-- Grand Total -->
            <div class="d-flex mb-3">
                <button class="btn btn-primary flex-fill fs-5" style="cursor:default;" id="grandTotalBtn"><div>@Model.Order.GrandTotal.ToString("F2")</div></button>
                <input type="hidden" asp-for="Order.GrandTotal" id="GrandTotalHidden" value="@Model.Order.GrandTotal" />
            </div>

            <!-- Bottom Action Buttons -->
            <div class="mt-auto">
                <div class="d-flex gap-2">
                    <button type="button" id="holdOrderBtn" class="btn btn-danger flex-fill fs-6">Hold</button>
                <button type="button"
                        class="btn btn-warning flex-fill fs-6"
                        onclick="window.location.href='@Url.Action("Index", "SaleOrder")';">
                    Cancel
                </button>
                <button type="submit" class="btn btn-success flex-fill fs-6">Update Order</button>
                </div>
            </div>       
    </div>
</div>    
</form>

<!------------------------------------------------------------ DISCOUNT MODAL ------------------------------------------------------------>
<div class="modal fade" id="discountModal" tabindex="-1">
    <div class="modal-dialog modal-md modal-dialog-top">
        <div class="modal-content">
            <div class="modal-header py-2 pt-3 border-0">
                <h4 class="modal-title fw-normal">Edit Discount</h4>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body pt-10">
                <h6>Enter New Value:</h6>
                <input type="number"
                       id="discountInput"
                       class="form-control"
                       value="@Model.Order.DiscountAmount"
                       placeholder="0.00"
                       min="0"
                       step="0.01" />
                <input type="hidden"
                       asp-for="Order.DiscountAmount"
                       id="DiscountHidden"
                       value="@Model.Order.DiscountAmount" />
            </div>
            <div class="modal-footer py-2 border-0">
                <button class="btn btn-secondary btn-md" data-bs-dismiss="modal">Cancel</button>
                <button class="btn btn-primary btn-md" onclick="applyDiscount()">Save Changes</button>
            </div>
        </div>
    </div>
</div>

<!-------------------------------------------------------------- TAX MODAL --------------------------------------------------------------->
<div class="modal fade" id="taxModal" tabindex="-1">
    <div class="modal-dialog modal-md modal-dialog-top">
        <div class="modal-content">
            <div class="modal-header py-2 pt-3 border-0">
                <h4 class="modal-title fw-normal">Edit Tax</h4>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body pt-10">
                <h6>Enter New Value:</h6>
                <input type="number"
                       id="taxInput"
                       class="form-control"
                       value="@Model.Order.TaxAmount"
                       placeholder="0.00"
                       min="0"
                       step="0.01" />
                <input type="hidden"
                       asp-for="Order.TaxAmount"
                       id="TaxHidden"
                       value="@Model.Order.TaxAmount" />
            </div>
            <div class="modal-footer py-2 border-0">
                <button class="btn btn-secondary btn-mg" data-bs-dismiss="modal">Cancel</button>
                <button class="btn btn-primary btn-md" onclick="applyTax()">Save Changes</button>
            </div>
        </div>
    </div>
</div>

<!---------------------------------------------------------- HELD INVOICE MODAL ----------------------------------------------------->
<div id="heldInvoicesModal" class="modal fade" tabindex="-1" aria-labelledby="heldInvoicesModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-md modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="heldInvoicesModalLabel">Held Invoices</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body modal-body-h">
                <!-- Content here -->
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<!---------------------------------------------------------- TABLE SELECTION MODAL -------------------------------------------------------------->
<div class="modal fade" id="tableSelectionModal" tabindex="-1" aria-labelledby="tableSelectionModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="tableSelectionModalLabel">Select Table</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="row g-3" id="tableListContainer">
                    <!-- Tables will be dynamically loaded here -->
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<!----------------------------------------------------------- FULL ADDRESS MODAL ---------------------------------------------------------------->
<div class="modal fade" id="fullAddressModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Shipping Address</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p id="fullAddressText" class="mb-0"></p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>               
            </div>
        </div>
    </div>
</div>

<!----------------------------------------------------------- PAYMENT MODAL ---------------------------------------------------------------->
<div class="modal fade" id="paymentModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Payment Methods</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="row g-3">
                    @foreach (var payment in Model.PaymentMethods)
                    {
                        <div class="col-md-4">
                            <div class="card payment-card text-center" style="cursor:pointer;" data-payment-id="@payment.Id" data-payment-name="@payment.PayName">
                                <div class="card-body">
                                    <i class="bi bi-credit-card fs-1 mb-2"></i>
                                    <h5 class="card-title">@payment.PayName</h5>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {  
<script>
    /* ===============================
       INITIALIZE ORDER FROM DATABASE
    =============================== */
    const currentOrder = @Html.Raw(Json.Serialize(Model.Order.OrderItems.Select(i => new {
        id = i.ItemId.ToString(),
        name = i.ItemName,
        price = i.Price,
        qty = i.Quantity,
        image = i.ItemImage 
    })));

    /* ===============================
       SELECT2 (Customers & Pickup)
    =============================== */
    $(document).ready(function () {

        $('.select2-ajax-category').select2({
            theme: 'bootstrap-5',
            placeholder: 'Select Customers',
            allowClear: true,
            ajax: {
                url: '@Url.Action("GetCustomers", "SaleOrder")',
                dataType: 'json',
                delay: 250,
                data: params => ({ search: params.term }),
                processResults: data => ({ results: data.results }),
                cache: true
            }
        });

        $('.select2-ajax-Pickup').select2({
            theme: 'bootstrap-5',
            placeholder: 'Select Pickup Points(OPT)',
            allowClear: true,
            ajax: {
                url: '@Url.Action("GetPickupPoints", "SaleOrder")',
                dataType: 'json',
                delay: 250,
                data: params => ({ search: params.term }),
                processResults: data => ({ results: data.results }),
                cache: true
            }
        });

        // Initial render
        renderOrder();
    });

    /* ===============================
       ORDER TYPE LOGIC
    =============================== */
    const tableDiv = document.getElementById('tableSelectDiv');
    const pickupDiv = document.getElementById('pickupSelectDiv');
    const deliveryDiv = document.getElementById('deliveryInputDiv');
    const orderTypeSelect = document.getElementById('orderTypeSelect');

    function hideAllOrderInputs() {
        tableDiv.classList.add('d-none');
        pickupDiv.classList.add('d-none');
        deliveryDiv.classList.add('d-none');
    }

    orderTypeSelect.addEventListener('change', () => {
        hideAllOrderInputs();
        document.getElementById('OrderTypeHidden').value = orderTypeSelect.value;

        if (orderTypeSelect.value === 'DINE IN') tableDiv.classList.remove('d-none');
        if (orderTypeSelect.value === 'PICKUP POINT') pickupDiv.classList.remove('d-none');
        if (orderTypeSelect.value === 'DELIVERY') deliveryDiv.classList.remove('d-none');
    });

    /* ===============================
       ORDER ITEMS LOGIC
    =============================== */
    const orderList = document.getElementById('orderList');

    document.querySelectorAll('.menu-item-card').forEach(card => {
        card.addEventListener('click', () => {
            const id = card.dataset.itemId;
            const name = card.dataset.itemName;
            const price = parseFloat(card.dataset.itemPrice);
            const image = card.dataset.itemImage || '/assets/images/upload.jpg';

            const existing = currentOrder.find(i => i.id === id);
            if (existing) existing.qty++;
            else currentOrder.push({ id, name, price, image, qty: 1 });

            renderOrder();
        });
    });

    /* ===============================
       RENDER ORDER + SUBTOTAL
    =============================== */
    function renderOrder() {
        orderList.innerHTML = '';
        let subtotal = 0;

        if (currentOrder.length === 0) {
            orderList.innerHTML = `
                <div class="text-center text-muted">
                    <i class="bi bi-basket fs-1 mb-2"></i>
                    <div class="fw-semibold">No items in order</div>
                </div>`;
            resetTotals();
            return;
        }

        currentOrder.forEach((item, index) => {
            subtotal += item.price * item.qty;

            const div = document.createElement('div');
            div.className = 'd-flex align-items-center mb-2 p-2 border rounded position-relative';

            div.innerHTML = `
            <button class="btn-close position-absolute remove-item-btn"
                    style="top: 5px; right: 5px; font-size: 0.7rem; padding: 0.2rem;"
                    aria-label="Remove"></button>
            <img src="${item.image}" style="width:60px;height:60px;object-fit:cover" class="rounded me-2">
            <div class="flex-grow-1">
                <div class="fw-semibold">${item.name}</div>
                <small>${item.price.toFixed(2)} × ${item.qty}</small>
            </div>
            <div class="btn-group btn-group-sm" role="group" aria-label="Quantity controls">
                <button type="button" class="btn btn-outline-primary dec">−</button>
                <button type="button" class="btn btn-outline-secondary qty-display border-0" disabled style="min-width:40px;">${item.qty}</button>
                <button type="button" class="btn btn-outline-primary inc">+</button>
            </div>
            <div class="fw-bold text-danger ms-2" style="min-width:60px;">${(item.price * item.qty).toFixed(2)}</div>
        `;

            div.querySelector('.remove-item-btn').onclick = () => {
                currentOrder.splice(index, 1);
                renderOrder();
            };

            div.querySelector('.inc').onclick = () => { item.qty++; renderOrder(); };
            div.querySelector('.dec').onclick = () => {
                item.qty--;
                if (item.qty <= 0) currentOrder.splice(index, 1);
                renderOrder();
            };

            orderList.appendChild(div);
        });

        document.getElementById('subtotal').innerText = subtotal.toFixed(2);
        document.getElementById('SubTotalHidden').value = subtotal.toFixed(2);
        calculateGrandTotal();
    }

    /* ===============================
       GRAND TOTAL CALCULATION
    =============================== */
    function calculateGrandTotal() {
        let subtotal = parseFloat(document.getElementById('subtotal').innerText) || 0;
        let discount = parseFloat(document.getElementById('DiscountHidden').value) || 0;
        let tax = parseFloat(document.getElementById('TaxHidden').value) || 0;

        let total = subtotal - discount + tax;
        if (total < 0) total = 0;

        document.getElementById('discount').innerText = discount.toFixed(2);
        document.getElementById('tax').innerText = tax.toFixed(2);
        document.getElementById('grandTotalBtn').innerHTML = `<div>${total.toFixed(2)}</div>`;

        document.getElementById('SubTotalHidden').value = subtotal.toFixed(2);
        document.getElementById('GrandTotalHidden').value = total.toFixed(2);
    }

    function resetTotals() {
        document.getElementById('subtotal').innerText = '0.00';
        document.getElementById('discount').innerText = '0.00';
        document.getElementById('tax').innerText = '0.00';
        document.getElementById('DiscountHidden').value = 0;
        document.getElementById('TaxHidden').value = 0;
        document.getElementById('grandTotalBtn').innerHTML = '<div>0.00</div>';
    }

    /* ===============================
       DISCOUNT MODAL
    =============================== */
    document.getElementById('openDiscountModal').onclick = () =>
        new bootstrap.Modal(document.getElementById('discountModal')).show();

    function applyDiscount() {
        document.getElementById('DiscountHidden').value =
            parseFloat(document.getElementById('discountInput').value || 0);
        bootstrap.Modal.getInstance(document.getElementById('discountModal')).hide();
        calculateGrandTotal();
    }

    /* ===============================
       TAX MODAL
    =============================== */
    document.getElementById('openTaxModal').onclick = () =>
        new bootstrap.Modal(document.getElementById('taxModal')).show();

    function applyTax() {
        document.getElementById('TaxHidden').value =
            parseFloat(document.getElementById('taxInput').value || 0);
        bootstrap.Modal.getInstance(document.getElementById('taxModal')).hide();
        calculateGrandTotal();
    }     
     
    /* ===============================
       TABLE SELECTION MODAL
    =============================== */
    document.getElementById('openTableModal').addEventListener('click', async function() {
        try {
            const response = await fetch('/SaleOrder/GetTables');
            const data = await response.json();

            const container = document.getElementById('tableListContainer');
            container.innerHTML = '';

            if (data.tables.length === 0) {
                container.innerHTML = `
                    <div class="col-12 text-center text-muted">
                        <i class="bi bi-x-circle fs-1 mb-2"></i>
                        <div class="fw-semibold">No Tables Found</div>
                        <small>Please add tables to the system.</small>
                    </div>`;
            } else {
                data.tables.forEach(table => {
                    const isAvailable = table.status === 'Available';
                    const statusClass = isAvailable ? 'success' : 'danger';
                    const statusText = table.status;

                    const tableCard = document.createElement('div');
                    tableCard.className = 'col-md-4 col-sm-6';
                    tableCard.innerHTML = `
                        <div class="card table-card ${isAvailable ? '' : 'opacity-75'}"
                             data-table-id="${table.id}"
                             data-table-name="${table.tableName}"
                             style="cursor: ${isAvailable ? 'pointer' : 'not-allowed'};">
                            <div class="card-body text-center">
                                <i class="bi bi-table fs-1 mb-2"></i>
                                <h5 class="card-title fw-bold">${table.tableName}</h5>                                    
                                <span class="badge bg-${statusClass}">${statusText}</span>
                            </div>
                        </div>`;

                    if (isAvailable) {
                        tableCard.querySelector('.table-card').addEventListener('click', function() {
                            selectTable(table.id, table.tableName);
                        });
                    }

                    container.appendChild(tableCard);
                });
            }

            const modal = new bootstrap.Modal(document.getElementById('tableSelectionModal'));
            modal.show();

        } catch (error) {
            console.error('Error fetching tables:', error);
            alert('Failed to load tables. Please try again.');
        }
    });

    function selectTable(tableId, tableName) {
        document.getElementById('TableIdHidden').value = tableId;
        document.getElementById('selectedTableText').innerText = tableName;

        const modal = bootstrap.Modal.getInstance(document.getElementById('tableSelectionModal'));
        modal.hide();
    }

    /* ===============================
       CUSTOMER ADDRESS LOGIC
    =============================== */
    $('.select2-ajax-category').on('select2:select', function (e) {
        var customerId = e.params.data.id;

        if (customerId) {
            $.ajax({
                url: '@Url.Action("GetCustomerAddress", "SaleOrder")',
                type: 'GET',
                data: { customerId: customerId },
                success: function (response) {
                    if (response.hasAddress) {
                        var truncatedAddress = truncateAddress(response.address, 20);
                        $('#deliveryAddressInput').val(truncatedAddress);
                        $('#deliveryAddressInput').attr('title', response.address);
                        $('#ShippingAddressHidden').val(response.address);
                    } else {
                        $('#deliveryAddressInput').val('No Address Found');
                        $('#deliveryAddressInput').attr('title', 'Click to add address');
                    }
                },
                error: function () {
                    alert('Failed to fetch customer address');
                }
            });
        }
    });

    function truncateAddress(text, maxLength) {
        if (!text) return '';
        text = text.trim();
        if (text.length <= maxLength) {
            return text;
        }
        return text.substring(0, maxLength) + '...';
    }

    $('#deliveryAddressInput').on('click', function() {
        var fullAddress = $('#ShippingAddressHidden').val();
        
        if (fullAddress && fullAddress.trim() !== '') {
            $('#fullAddressText').text(fullAddress);
            var modal = new bootstrap.Modal(document.getElementById('fullAddressModal'));
            modal.show();
        }
    });

    // Place Order - Convert items to JSON before submit
    document.getElementById('posForm').addEventListener('submit', function(e) {
        if (currentOrder.length === 0) {
            e.preventDefault();
            alert('Please add items to order first!');
            return false;
        }

        const orderItemsJson = JSON.stringify(currentOrder.map(item => ({
            ItemId: item.id,
            ItemName: item.name,
            Price: item.price,
            Quantity: item.qty
        })));

        let orderItemsInput = document.getElementById('OrderItemsJson');
        if (!orderItemsInput) {
            orderItemsInput = document.createElement('input');
            orderItemsInput.type = 'hidden';
            orderItemsInput.id = 'OrderItemsJson';
            orderItemsInput.name = 'OrderItemsJson';
            this.appendChild(orderItemsInput);
        }
        orderItemsInput.value = orderItemsJson;

        return true;
    });

    /* ===============================
       CATEGORY FILTER
    =============================== */
    document.querySelectorAll('.category-filter').forEach(cat => {
        cat.addEventListener('click', function() {
            const categoryId = this.dataset.categoryId;
            
            document.querySelectorAll('.category-filter').forEach(c => c.classList.remove('active'));
            this.classList.add('active');
            
            document.querySelectorAll('.menu-item').forEach(item => {
                if (item.dataset.category === categoryId) {
                    item.style.display = 'flex';
                } else {
                    item.style.display = 'none';
                }
            });
        });
    });

    /* ===============================
       SEARCH FILTER
    =============================== */
    document.getElementById('itemSearch').addEventListener('input', function() {
        const search = this.value.toLowerCase();
        document.querySelectorAll('.menu-item-card').forEach(card => {
            const name = card.dataset.itemName.toLowerCase();
            if (name.includes(search)) {
                card.closest('.menu-item').style.display = 'flex';
            } else {
                card.closest('.menu-item').style.display = 'none';
            }
        });
    });

    /* ===============================
       PAYMENT MODAL
    =============================== */
    document.querySelectorAll('.payment-card').forEach(card => {
        card.addEventListener('click', function() {
            const paymentId = this.dataset.paymentId;
            const paymentName = this.dataset.paymentName;
            
            alert(`Payment method selected: ${paymentName}`);
            bootstrap.Modal.getInstance(document.getElementById('paymentModal')).hide();
            
            // Aap yahan payment processing logic add kar sakte hain
        });
    });

</script>

<!-------------------------------------------------------- HELD ORDER JS (SAME AS CREATE) ------------------------------------------------------->
<script>
    /* HOLD ORDER FUNCTIONALITY - Same as Create */
    document.getElementById('holdOrderBtn').addEventListener('click', async function() {
        if (currentOrder.length === 0) {
            alert('Please add items to order first!');
            return;
        }

        const holdBtn = this;
        const originalText = holdBtn.innerHTML;
        holdBtn.innerHTML = 'Holding...';
        holdBtn.disabled = true;

        const holdData = {
            OrderNumber: null,
            OrderType: document.getElementById('OrderTypeHidden').value,
            CustomerId: document.getElementById('CustomerId').value || null,
            TableId: document.getElementById('TableIdHidden').value || null,
            PickUpId: document.getElementById('Order_PickUpId').value || null,
            DelivaryAddress: document.getElementById('ShippingAddressHidden').value || null,
            PaymentId: null,
            PaymentStatus: "Unpaid",
            SubTotal: parseFloat(document.getElementById('SubTotalHidden').value) || 0,
            TaxAmount: parseFloat(document.getElementById('TaxHidden').value) || 0,
            DiscountAmount: parseFloat(document.getElementById('DiscountHidden').value) || 0,
            GrandTotal: parseFloat(document.getElementById('GrandTotalHidden').value) || 0,
            Items: currentOrder.map(item => ({
                ItemId: item.id,
                ItemName: item.name,
                Price: item.price,
                Quantity: item.qty,
                ItemImage: item.image,
                Total: item.price * item.qty
            }))
        };

        try {
            const response = await fetch('@Url.Action("HoldOrder", "SaleOrder")', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                },
                body: JSON.stringify(holdData)
            });

            const result = await response.json();

            if (result.success) {
                alert(`Order held successfully! Order #${result.orderNumber}`);
                window.location.href = '@Url.Action("Index", "SaleOrder")';
            } else {
                alert('Failed to hold order: ' + result.message);
            }
        } catch (error) {
            console.error('Error holding order:', error);
            alert('An error occurred while holding the order.');
        } finally {
            holdBtn.innerHTML = originalText;
            holdBtn.disabled = false;
        }
    });

    /* GET HELD ORDERS COUNT */
    async function updateHeldOrdersCount() {
        try {
            const response = await fetch('@Url.Action("GetHeldOrdersCount", "SaleOrder")');
            const data = await response.json();
            document.getElementById('heldCount').innerText = data.count;
        } catch (error) {
            console.error('Error updating held count:', error);
        }
    }

    /* LOAD HELD ORDERS IN MODAL */
    document.getElementById('openHeldModal').addEventListener('click', async function() {
        try {
            const response = await fetch('@Url.Action("GetHeldOrders", "SaleOrder")');
            const content = await response.text();
            document.querySelector('#heldInvoicesModal .modal-body').innerHTML = content;
            await updateHeldOrdersCount();
        } catch (error) {
            console.error('Error loading held orders:', error);
            document.querySelector('#heldInvoicesModal .modal-body').innerHTML = '<div class="alert alert-danger">Failed to load held orders</div>';
        }
    });

    // Load held orders count on page load
    document.addEventListener('DOMContentLoaded', function() {
        updateHeldOrdersCount();
    });
</script>
}
