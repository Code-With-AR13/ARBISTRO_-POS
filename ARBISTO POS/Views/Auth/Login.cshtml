
@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Login";
}

<!--! ================================================================ !-->
<!--! [Start] Main Content !-->
<!--! ================================================================ !-->
<main class="auth-creative-wrapper">
    <div class="auth-creative-inner">
        <div class="creative-card-wrapper">
            <div class="card my-4 overflow-hidden" style="z-index: 1">
                <div class="row flex-1 g-0">

                    <!-- LEFT SIDE (FORM) -->
                    <div class="col-lg-6 h-100 my-auto order-1 order-lg-0">

                        <!-- CENTER LOGO -->
                        <div class="wd-50 bg-white p-2 rounded-circle shadow-lg position-absolute translate-middle top-50 start-50 d-none d-lg-block">
                            <img src="~/assets/images/logo-Min.png" alt="Logo" class="img-fluid">
                        </div>

                        <div class="creative-card-body card-body p-sm-5">

                            <h2 class="fs-20 fw-bolder mb-4">Login</h2>
                            <h4 class="fs-13 fw-bold mb-2">Login to your account</h4>
                            <p class="fs-12 fw-medium text-muted">
                                Please enter your credentials to access the dashboard.
                            </p>

                            <!-- 🔴 FUNCTIONAL FORM START -->
                            <form asp-action="Login" method="post" class="w-100 mt-4 pt-2">

                                @Html.AntiForgeryToken()
                                <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />

                                <!-- EMAIL -->
                                <div class="mb-4">
                                    <input name="email"
                                           type="email"
                                           class="form-control"
                                           placeholder="Email or Username"
                                           required
                                           autofocus />
                                </div>

                                <!-- PASSWORD -->
                                <div class="mb-3">
                                    <input name="password"
                                           type="password"
                                           class="form-control"
                                           placeholder="Password"
                                           required />
                                </div>

                                <!-- REMEMBER + FORGOT -->
                                <div class="d-flex align-items-center justify-content-between">
                                    <div class="custom-control custom-checkbox">
                                        <input type="checkbox"
                                               class="custom-control-input"
                                               id="rememberMe"
                                               name="rememberMe"
                                               value="true">
                                        <label class="custom-control-label c-pointer" for="rememberMe">
                                            Remember Me
                                        </label>
                                    </div>

                                    <div>
                                        <a asp-action="ForgotPassword" class="fs-11 text-primary">
                                            Forgot password?
                                        </a>
                                    </div>
                                </div>

                                <!-- LOGIN BUTTON -->
                                <div class="mt-5">
                                    <button type="submit" class="btn btn-lg btn-primary w-100">
                                        Login
                                    </button>
                                </div>

                            </form>
                            <!-- 🔴 FUNCTIONAL FORM END -->
                            <!-- OPTIONAL SOCIAL LOGIN (DESIGN ONLY) -->
                           

                            <div class="mt-5 text-muted">
                                <span>Don't have an account?</span>
                                <span class="fw-bold">Ask your administrator</span>
                            </div>

                        </div>
                    </div>

                    <!-- RIGHT SIDE IMAGE -->
                    <div class="col-lg-6 bg-primary order-0 order-lg-1">
                        <div class="h-100 d-flex align-items-center justify-content-center">
                            <img src="~/assets/images/logo-Min.png" alt="" class="img-fluid">
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</main>
<!--! ================================================================ !-->
<!--! [End] Main Content !-->
<!--! ================================================================ !-->
@section Scripts {
    <script>
        $(function () {
            // Toastr Configuration - Right Top Corner
        toastr.options = {
            "closeButton": true,
            "debug": false,
            "newestOnTop": true,
            "progressBar": true,
            "positionClass": "toast-top-right",  // Right top corner
            "preventDuplicates": false,
            "onclick": null,
            "showDuration": "300",
            "hideDuration": "1000",
            "timeOut": "5000",
            "extendedTimeOut": "1000",
            "showEasing": "swing",
            "hideEasing": "linear",
            "showMethod": "fadeIn",
            "hideMethod": "fadeOut"
        };

        // Success Toaster Check karein
        @if (TempData["ToastrSuccess"] != null)
        {
                    <text>
                        toastr.success("@TempData["ToastrSuccess"]");
                    </text>
        }
            
            @if (TempData["ToastrError"] != null)
            {
                    <text>                       
                        toastr.error("@TempData["ToastrError"]");
                    </text>
            }

        });
    </script>
}

