/* ===============================
   PAYMENT MODAL HANDLING
=============================== */

// Modal show event - Order Status Check + Data Population
document.getElementById('paymentModal').addEventListener('show.bs.modal', function (event) {
    // Get order status
    const orderStatus = document.getElementById('OrderStatusHidden').value;
    
    console.log('Checking Order Status:', orderStatus); // Debug
    
    // Check order status
    if (orderStatus === 'Completed') {
        event.preventDefault(); // Modal opening cancel karo
        toastr.info('This Order Payment Has Already Completed', 'Payment Status');
        return false;
    } 
    else if (orderStatus === 'Preparing') {
        event.preventDefault(); // Modal opening cancel karo
        toastr.warning('This order payment cannot be processed now because this is in the kitchen', 'Kitchen Alert');
        return false;
    }
    
    // Status valid hai - Modal data populate karo
    calculateGrandTotal();
    const grandTotal = parseFloat(document.getElementById('GrandTotalHidden').value) || 0;
    
    console.log('Grand Total:', grandTotal); // Debug
    
    document.getElementById('paymentTotalAmount').innerText = grandTotal.toFixed(2);
    document.getElementById('paymentMethodSelect').value = '';
    document.getElementById('receivedAmountInput').value = grandTotal.toFixed(2);
});

// Pay Now Button (Modal ke andar) - Payment Processing
document.getElementById('ConfirmpaymentBtn').addEventListener('click', async function() {
    const paymentMethodId = document.getElementById('paymentMethodSelect').value;
    const receivedAmount = parseFloat(document.getElementById('receivedAmountInput').value) || 0;
    const grandTotal = parseFloat(document.getElementById('GrandTotalHidden').value) || 0;
    const orderId = parseInt(document.querySelector('input[name="Order.OrderId"]').value);
    
    // Validation
    if (!paymentMethodId) {
        toastr.error('Please select a payment method!', 'Validation Error');
        return false;
    }
    
    if (receivedAmount < grandTotal) {
        toastr.error('Received amount cannot be less than total amount!', 'Validation Error');
        return false;
    }
    
    // Button disable karo processing ke dauran
    const btn = this;
    const originalText = btn.innerHTML;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Processing...';
    btn.disabled = true;
    
    // Payment data prepare karo
    const paymentData = {
        OrderId: orderId,
        PaymentMethodId: parseInt(paymentMethodId),
        TotalAmount: grandTotal,
        ReceivedAmount: receivedAmount
    };
    
    console.log('Sending Payment Data:', paymentData); // Debug
    
    try {
        // Backend API call
        const response = await fetch('@Url.Action("ProcessPayment", "SaleOrder")', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
            },
            body: JSON.stringify(paymentData)
        });
        
        const result = await response.json();
        
        console.log('Backend Response:', result); // Debug
        
        if (result.success) {
            toastr.success(result.message || 'Payment processed successfully!', 'Success');
            
            // Close modal
            const modalInstance = bootstrap.Modal.getInstance(document.getElementById('paymentModal'));
            modalInstance.hide();
            
            // Redirect to orders list
            setTimeout(() => {
                window.location.href = '@Url.Action("Index", "SaleOrder")';
            }, 1500);
        } else {
            toastr.error(result.message || 'Payment processing failed!', 'Error');
        }
    } catch (error) {
        console.error('Payment Error:', error);
        toastr.error('An error occurred while processing payment!', 'Error');
    } finally {
        // Button restore karo
        btn.innerHTML = originalText;
        btn.disabled = false;
    }
});



</script>
