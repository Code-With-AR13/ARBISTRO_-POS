@model IEnumerable<ARBISTO_POS.Models.SaleOrders>

@{
    ViewData["Title"] = "Sale Orders";
}

<main class="nxl-container-fluid">
    <div class="nxl-content">
        <!-- Page Header -->
        <div class="page-header">
            <div class="page-header-left d-flex align-items-center">
                <div class="page-header-title">
                    <h5 class="m-b-10">Sale Orders</h5>
                </div>
                <ul class="breadcrumb">
                    <li class="breadcrumb-item">
                        <a asp-controller="Home" asp-action="Index">Home</a>
                    </li>
                    <li class="breadcrumb-item active">Sale Orders</li>
                </ul>
            </div>
            <div class="page-header-right ms-auto">
                <div class="d-flex align-items-center gap-2 page-header-right-items-wrapper">
                    <a asp-controller="SaleOrder" asp-action="Create" class="btn btn-primary">
                        <i class="feather-plus me-2"></i>
                        <span>New Sale Order</span>
                    </a>
                </div>
            </div>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                <i class="feather-check-circle me-2"></i>
                <strong>Success!</strong> @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <div class="main-content">
            <div class="row">
                <div class="col-lg-12">
                    <div class="card stretch stretch-full">
                        <div class="card-header">
                            <h5 class="card-title mb-0">
                                <i class="feather-list me-2"></i>All Sale Orders
                            </h5>
                        </div>

                        <div class="card-body p-0">
                            <div class="table-responsive">
                                <table class="table table-hover align-middle dataTable" id="saleTable">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Order No</th>
                                            <th>Customer Name</th>
                                            <th>Order Taker</th>
                                            <th>Order Type</th>
                                            <th>Order Status</th>
                                            <th>Payment Status</th>
                                            <th class="text-center" style="width:120px;">Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @* AJAX DATA *@
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>

@section Scripts {
    <script>
        $(document).ready(function () {

            var table = $('#saleTable').DataTable({
                order: [[0, 'desc']],
                "ajax": {
                    "url": "/SaleOrder/GetAll", // ⚠️ backend required
                    "type": "GET",
                    "dataSrc": ""
                },
                "columns": [
                    {
                        "data": null,
                        "render": function (data) {
                            return `
                            <div class="d-flex flex-column">
                                <span class="fw-semibold">${data.orderNumber}</span>
                                <small class="text-muted">Created At: ${data.orderDate}</small>
                            </div>`;
                        }
                    },
                    {
                        "data": null,
                        "render": function (data) {
                            return `
                            <div class="d-flex flex-column">
                                <span class="fw-semibold">${data.customerName || ''}</span>
                                <small class="text-muted">Phone No: ${data.phoneNo || ''}</small>
                            </div>`;
                        }
                    },
                    { "data": "createdBy" },
                    {
                        "data": "orderType",
                        "render": function (data) {
                            if (data === "DINE IN") return '<span class="badge bg-primary">Dine In</span>';
                            if (data === "PICKUP POINT") return '<span class="badge bg-secondary">Pickup Point</span>';
                            if (data === "DELIVERY") return '<span class="badge bg-success">Delivery</span>';
                            return data;
                        }
                    },
                    {
                        "data": "orderStatus",
                        "render": function (data) {
                            if (data === "Pending") return '<span class="badge bg-primary">Pending</span>';
                            if (data === "Preparing") return '<span class="badge bg-warning">Preparing</span>';
                            if (data === "Ready") return '<span class="badge bg-secondary">Ready</span>';
                            if (data === "Completed") return '<span class="badge bg-success">Completed</span>';
                            return data;
                        }
                    },
                    {
                        "data": "paymentStatus",
                        "render": function (data) {
                            if (data === "Unpaid") return '<span class="badge bg-danger">Unpaid</span>';
                            if (data === "Paid") return '<span class="badge bg-success">Paid</span>';
                            return data;
                        }
                    },
                    {
                        "data": null,
                        "orderable": false,
                        "className": "text-center",
                        "render": function (data) {
                            return `
                            <div class="d-inline-flex gap-1">
                                <a href="/SaleOrder/Edit/${data.orderId}" class="btn btn-sm btn-light">
                                    <i class="feather-edit-3"></i>
                                </a>
                            </div>
                            <div class="d-inline-flex gap-1">
                                <a href="/SaleOrder/Invoice/${data.orderId}" class="btn btn-sm btn-light">
                                    <i class="feather-printer"></i>
                                </a>
                            </div>
                            <div class="d-inline-flex gap-1">
                                <button class="btn btn-sm btn-light js-delete"
                                        data-id="${data.orderId}">
                                    <i class="feather-trash"></i>
                                </button>

                                <form id="delete-form-${data.orderId}"
                                      action="/SaleOrder/DeleteConfirmed"
                                      method="post"
                                      style="display:none;">
                                    <input name="__RequestVerificationToken"
                                           value="${$('input[name="__RequestVerificationToken"]').val()}" />
                                    <input type="hidden" name="id" value="${data.orderId}" />
                                </form>
                            </div>`;
                        }
                    }
                ]
            });

            // DELETE (UNCHANGED LOGIC)
            $(document).on('click', '.js-delete', function (e) {
                e.preventDefault();

                const id = $(this).data('id');
                const form = $('#delete-form-' + id);
                const token = $('input[name="__RequestVerificationToken"]').val();

                Swal.fire({
                    title: 'Are you sure?',
                    text: 'This sale order and its items will be permanently deleted!',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#d33',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: 'Yes, delete it!',
                    cancelButtonText: 'Cancel'
                }).then((result) => {
                    if (result.isConfirmed) {
                        $.ajax({
                            url: form.attr('action'),
                            type: 'POST',
                            data: { id: id, __RequestVerificationToken: token },
                            success: function (res) {
                                if (res.success) {
                                    table.ajax.reload();
                                    Swal.fire('Deleted!', res.message, 'success');
                                } else {
                                    Swal.fire('Error', res.message, 'error');
                                }
                            }
                        });
                    }
                });
            });

            setTimeout(() => $('.alert-success').fadeOut('slow'), 5000);
        });
    </script>
}