@model IEnumerable<ARBISTO_POS.Models.Items>

@{
    ViewData["Title"] = "Items";
}

<main class="nxl-container-fluid">
    <div class="nxl-content">

        <!-- Page Header -->
        <div class="page-header">
            <div class="page-header-left d-flex align-items-center">
                <div class="page-header-title">
                    <h5 class="m-b-10">@ViewData["Title"]</h5>
                </div>
                <ul class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
                    <li class="breadcrumb-item active">@ViewData["Title"]</li>
                </ul>
            </div>

            <div class="page-header-right ms-auto">
                <div class="d-flex align-items-center gap-2 page-header-right-items-wrapper">
                    <a asp-controller="Items" asp-action="Create" class="btn btn-primary">
                        <i class="feather-plus me-2"></i>
                        <span>New Item</span>
                    </a>
                </div>
            </div>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="feather-check-circle me-2"></i>
                <strong>Success!</strong> @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <div class="main-content">
            <div class="row">
                <div class="col-lg-12">
                    <div class="card stretch stretch-full">

                        <div class="card-header">
                            <h5 class="card-title mb-0">
                                <i class="feather-shopping-bag me-2"></i>All Items
                            </h5>
                        </div>

                        <div class="card-body p-0">
                            <div class="table-responsive">

                                <!-- TABLE -->
                                <table class="table table-hover align-middle dataTable">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Item</th>
                                            <th>Category</th>
                                            <th>Ingredient</th>
                                            <th>Cost</th>
                                            <th>Price</th>
                                            <th class="text-center" style="width: 120px;">Actions</th>
                                        </tr>
                                    </thead>

                                    <!-- ❌ REMOVE SERVER LOOP -->
                                    <tbody></tbody>

                                </table>

                            </div>
                        </div>

                    </div>
                </div>
            </div>
        </div>

    </div>
</main>

@section Scripts {
    <script>
        $(document).ready(function () {

            var table = $('.dataTable').DataTable({
                
                serverSide: false, // change to true if server-side paging
                ajax: {
                    url: '/Items/GetItems', // 👈 CREATE THIS ACTION
                    type: 'GET',
                    dataSrc: ''
                },

                columns: [

                    {
                        data: null,
                        render: function (data) {

                            let image = data.cateImage
                                ? `<img src="${data.cateImage}" class="rounded-circle border" style="width:80px;height:80px;object-fit:cover;" onerror="this.src='/assets/images/upload.jpg'">`
                                : `<img src="/assets/images/upload.jpg" class="rounded-circle border" style="width:80px;height:80px;">`;

                            let desc = data.itemDiscription
                                ? data.itemDiscription.substring(0, 50) + (data.itemDiscription.length > 50 ? '...' : '')
                                : '';

                            return `
                            <div class="d-flex align-items-center">
                                <div class="me-3">${image}</div>
                                <div class="d-flex flex-column">
                                    <span class="fw-semibold">${data.itemName}</span>
                                    <span class="text-muted small">${desc}</span>
                                </div>
                            </div>`;
                        }
                    },

                    {
                        data: 'foodCategory.cateName',
                        render: function (data) {
                            return `<span class="badge bg-light text-dark">${data}</span>`;
                        }
                    },

                    {
                        data: 'itemIngredients',
                        render: function (data) {
                            if (!data) return '';
                            return data.map(x => x.ingredient.name).join(', ');
                        }
                    },

                    {
                        data: 'itemCost',
                        render: function (data) {
                            return `<span class="text-muted">${data}.00</span>`;
                        }
                    },

                    {
                        data: 'itemPrice',
                        render: function (data) {
                            return `<strong>${data}.00</strong>`;
                        }
                    },

                    {
                        data: 'itemId',
                        orderable: false,
                        className: "text-center",
                        render: function (id) {

                            return `
                            <div class="d-inline-flex gap-1">

                                <a href="/Items/Edit/${id}" class="btn btn-sm btn-light">
                                    <i class="feather-edit-3"></i>
                                </a>

                                <form method="post" action="/Items/Delete/${id}" class="d-inline delete-form" id="delete-form-${id}">
                                    <input name="__RequestVerificationToken" type="hidden" value="${$('input[name="__RequestVerificationToken"]').val()}"/>
                                    <button type="button" class="btn btn-sm btn-light js-delete" data-id="${id}">
                                        <i class="feather-trash-2"></i>
                                    </button>
                                </form>

                            </div>`;
                        }
                    }
                ]
            });

            // auto hide alerts
            setTimeout(function () {
                $('.alert-success, .alert-danger').fadeOut('slow');
            }, 5000);

            // DELETE FUNCTION (UNCHANGED)
            $(document).on('click', '.js-delete', function (e) {

                e.preventDefault();

                const id = $(this).data('id');
                const form = $('#delete-form-' + id);
                const token = form.find('input[name="__RequestVerificationToken"]').val();

                Swal.fire({
                    title: 'Are you sure?',
                    text: 'This item will be permanently deleted.',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#d33',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: 'Yes, delete it'
                }).then((result) => {

                    if (result.isConfirmed) {

                        $.ajax({
                            url: form.attr('action'),
                            type: 'POST',
                            data: {
                                id: id,
                                __RequestVerificationToken: token
                            },
                            success: function (res) {

                                if (res.success) {
                                    table.ajax.reload(); // ✅ reload table
                                    Swal.fire('Deleted!', res.message, 'success');
                                }
                                else {
                                    Swal.fire('Error', res.message, 'error');
                                }
                            },
                            error: function () {
                                Swal.fire('Error', 'Something went wrong', 'error');
                            }
                        });
                    }
                });
            });

        });
    </script>
}