@using ARBISTO_POS.Models
@model AppSetttingPrinter

@{
    ViewData["Title"] = "App Setting";
}

<!-- Toastr CSS CDN -->
<link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" rel="stylesheet" />

<main class="nxl-container-fluid">
    <div class="nxl-content without-header nxl-full-content">
        <div class="main-content d-flex">
            <div class="content-sidebar content-sidebar-md" data-scrollbar-target="#psScrollbarInit">
                <div class="content-sidebar-header bg-white sticky-top hstack justify-content-between">
                    <h4 class="fw-bolder mb-0">App Settings</h4>
                </div>
                <div class="content-sidebar-body">
                    <ul class="nav flex-column nxl-content-sidebar-item">
                        <li class="nav-item">
                            <a class="nav-link active" asp-action="Index">
                                <i class="feather-check-circle"></i>
                                <span>Printer Setting</span>
                            </a>
                        </li>
                    </ul>
                </div>
            </div>

            <div class="content-area" data-scrollbar-target="#psScrollbarInit">
                <form asp-action="Index" method="post">
                    @Html.AntiForgeryToken()

                    <div class="content-area-header bg-white sticky-top">
                        <div class="page-header-right ms-auto">
                            <div class="d-flex align-items-center gap-3 page-header-right-items-wrapper">
                                <button type="submit" class="btn btn-primary">
                                    <i class="feather-save me-2"></i>
                                    <span>Save Changes</span>
                                </button>
                            </div>
                        </div>
                    </div>

                    <div class="content-area-body">
                        <div class="card mb-0">
                            <div class="card-body">
                                <div class="mb-5">
                                    <label class="form-label">Allow printer in kitchen instead of screen.</label>
                                    <select asp-for="KitchenPrinter" class="form-select" data-select2-selector="icon">
                                        <option value="Yes" data-icon="feather-check text-success">Yes</option>
                                        <option value="No" data-icon="feather-x text-danger">No</option>
                                    </select>
                                    <small class="form-text text-muted">Allow printer in kitchen instead of screen. [Ex: Yes/No]</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</main>

<!-- jQuery CDN (if not already included) -->
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<!-- Toastr JS CDN -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>

<script type="text/javascript">
    @if (TempData["SuccessMessage"] != null)
    {
            <text>
            toastr.options = {
                "closeButton": true,
                "debug": false,
                "newestOnTop": true,
                "progressBar": true,
                "positionClass": "toast-top-right",
                "preventDuplicates": false,
                "onclick": null,
                "showDuration": "300",
                "hideDuration": "1000",
                "timeOut": "3000",
                "extendedTimeOut": "1000",
                "showEasing": "swing",
                "hideEasing": "linear",
                "showMethod": "fadeIn",
                "hideMethod": "fadeOut"
            };
            toastr.success('@TempData["SuccessMessage"]');
            </text>
    }

    @if (TempData["ErrorMessage"] != null)
    {
            <text>
            toastr.options = {
                "closeButton": true,
                "debug": false,
                "newestOnTop": true,
                "progressBar": true,
                "positionClass": "toast-top-right",
                "preventDuplicates": false,
                "onclick": null,
                "showDuration": "300",
                "hideDuration": "1000",
                "timeOut": "3000",
                "extendedTimeOut": "1000",
                "showEasing": "swing",
                "hideEasing": "linear",
                "showMethod": "fadeIn",
                "hideMethod": "fadeOut"
            };
            toastr.error('@TempData["ErrorMessage"]');
            </text>
    }
</script>
