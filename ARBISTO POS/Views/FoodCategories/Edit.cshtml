@model ARBISTO_POS.Models.FoodCategories

@{
    ViewData["Title"] = "Edit Category";
}

<!-- [ page-header ] start -->
<div class="page-header">
    <div class="page-header-left d-flex align-items-center">
        <ul class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li class="breadcrumb-item"><a asp-controller="FoodCategories" asp-action="Index">Categories</a></li>
            <li class="breadcrumb-item active">Edit</li>
        </ul>
    </div>
    <div class="page-header-right ms-auto">
        <div class="d-flex align-items-center gap-2 page-header-right-items-wrapper">
            <a asp-controller="FoodCategories" asp-action="Index" class="btn btn-primary">
                <i class="feather-arrow-left me-2"></i>
                <span>Back To Category</span>
            </a>
        </div>
    </div>
</div>
<!-- [ page-header ] end -->
<!-- [ Main Content ] start -->
<div class="main-content">
    <div class="row">
        <div class="col-lg-12">
            <div class="card border-top-0">
                <div class="card-header">
                    <h5 class="card-title">
                        <i class="feather-edit-3 me-2"></i>Edit Category
                    </h5>
                </div>

                <div class="card-body">
                    <!-- Validation Summary -->
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <form asp-action="Edit" method="post" enctype="multipart/form-data" id="categoryForm">
                        @* hidden id *@
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="CateImage" />

                        <div class="row">
                            <!-- Left Column - Image Upload -->
                            <div class="col-lg-4 mb-4">
                                <div class="card bg-light">
                                    <div class="card-body text-center">
                                        <label class="form-label fw-semibold">Category Image</label>

                                        <div class="position-relative mx-auto" style="width: 200px; height: 200px;">
                                            <div class="border border-2 border-dashed rounded-3 overflow-hidden h-100 w-100 position-relative bg-white"
                                                 id="avatarDiv"
                                                 style="cursor: pointer;">
                                                <img id="avatarPreview"
                                                     src="@(string.IsNullOrEmpty(Model.CateImage) ? Url.Content("~/assets/images/upload.jpg") : Model.CateImage)"
                                                     class="img-fluid h-100 w-100"
                                                     style="object-fit: cover;"
                                                     alt="Category Image" />
                                                <div class="position-absolute start-0 top-0 w-100 h-100 d-flex align-items-center justify-content-center bg-dark bg-opacity-50"
                                                     id="uploadOverlay"
                                                     style="opacity: 0; transition: opacity 0.3s;">
                                                    <i class="feather-camera text-white" style="font-size: 32px;"></i>
                                                </div>
                                            </div>
                                            <input type="file"
                                                   accept="image/png,image/jpg,image/jpeg"
                                                   asp-for="ImageFile"
                                                   id="fileInput"
                                                   style="display: none;" />
                                        </div>

                                        <div class="mt-3">
                                            <small class="text-muted d-block"><i class="feather-info me-1"></i>Click image to change</small>
                                            <small class="text-muted d-block">Size: 150x150px (Max 2MB)</small>
                                            <small class="text-muted d-block">Format: PNG, JPG, JPEG</small>
                                        </div>
                                        <span asp-validation-for="ImageFile" class="text-danger small"></span>
                                    </div>
                                </div>
                            </div>

                            <!-- Right Column - Form Fields -->
                            <div class="col-lg-8">
                                <!-- Category Name -->
                                <div class="mb-3">
                                    <label asp-for="CateName" class="form-label fw-semibold">
                                        Category Name <span class="text-danger">*</span>
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="feather-tag"></i></span>
                                        <input type="text"
                                               class="form-control"
                                               asp-for="CateName"
                                               placeholder="e.g., Appetizers, Main Course, Desserts" />
                                    </div>
                                    <span asp-validation-for="CateName" class="text-danger small"></span>
                                </div>

                                <!-- Description -->
                                <div class="mb-3">
                                    <label asp-for="Description" class="form-label fw-semibold">
                                        Description
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text">
                                            <i class="feather-file-text"></i>
                                        </span>
                                        <textarea class="form-control"
                                                  asp-for="Description"
                                                  placeholder="Enter category description..."
                                                  rows="4"></textarea>
                                    </div>

                                    <span asp-validation-for="Description" class="text-danger small"></span>
                                </div>

                                <!-- Form Actions -->
                                <div class="d-flex gap-2 justify-content-end mt-4">
                                    <a asp-action="Index" class="btn btn-light">
                                        <i class="feather-x me-1"></i>Cancel
                                    </a>
                                    <button type="submit" class="btn btn-primary">
                                        <i class="feather-save me-1"></i>Update Category
                                    </button>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- [ Main Content ] end -->
@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        $(document).ready(function () {
            const avatarDiv = $('#avatarDiv');
            const fileInput = $('#fileInput');
            const avatarPreview = $('#avatarPreview');
            const uploadOverlay = $('#uploadOverlay');

            // Trigger file input on div click
            avatarDiv.on('click', function () {
                fileInput.click();
            });

            // Show overlay on hover
            avatarDiv.on('mouseenter', function () {
                uploadOverlay.css('opacity', '1');
            }).on('mouseleave', function () {
                uploadOverlay.css('opacity', '0');
            });

            // Handle file selection and preview
            fileInput.on('change', function (e) {
                const file = e.target.files[0];

                if (file) {
                    if (file.size > 2 * 1024 * 1024) {
                        alert('File size must be less than 2MB');
                        fileInput.val('');
                        return;
                    }

                    const validTypes = ['image/png', 'image/jpg', 'image/jpeg'];
                    if (!validTypes.includes(file.type)) {
                        alert('Only PNG, JPG, and JPEG files are allowed');
                        fileInput.val('');
                        return;
                    }

                    const reader = new FileReader();
                    reader.onload = function (event) {
                        avatarPreview.attr('src', event.target.result);
                        avatarDiv.addClass('border-success');
                        setTimeout(() => {
                            avatarDiv.removeClass('border-success');
                        }, 1000);
                    };
                    reader.readAsDataURL(file);
                }
            });
        });
    </script>
}
