@model IEnumerable<ARBISTO_POS.Models.Employees>
@{
    ViewData["Title"] = "Employees";
}

<main class="nxl-container-fluid">
    <div class="nxl-content">

        <div class="page-header">
            <div class="page-header-left d-flex align-items-center">
                <div class="page-header-title">
                    <h5 class="m-b-10">@ViewData["Title"]</h5>
                </div>
                <ul class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
                    <li class="breadcrumb-item active">@ViewData["Title"]</li>
                </ul>
            </div>
            <div class="page-header-right ms-auto">
                <div class="d-flex align-items-center gap-2 page-header-right-items-wrapper">
                    <a asp-controller="Employees" asp-action="Create" class="btn btn-primary">
                        <i class="feather-plus me-2"></i>
                        <span>New Employee</span>
                    </a>
                </div>
            </div>
        </div>

        <div id="ajax-alert-placeholder"></div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="feather-check-circle me-2"></i>
                <strong>Success!</strong> @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <div class="main-content">
            <div class="row">
                <div class="col-lg-12">
                    <div class="card stretch stretch-full">
                        <div class="card-header">
                            <h5 class="card-title mb-0">
                                <i class="feather-list me-2"></i>All Employees
                            </h5>
                        </div>

                        <div class="card-body p-0">
                            <div class="table-responsive">

                                <!-- ✅ Added ID -->
                                <table id="employeeTable" class="table table-hover align-middle dataTable">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Employee</th>
                                            <th>Gender</th>
                                            <th>Phone No</th>
                                            <th>Shift</th>
                                            <th>Role</th>
                                            <th>Salary</th>
                                            <th>Status</th>
                                            <th>Description</th>
                                            <th class="text-center" style="width: 120px;">Actions</th>
                                        </tr>
                                    </thead>

                                    <!-- ❌ Removed foreach -->
                                    <tbody>
                                        <!-- AJAX DATA -->
                                    </tbody>
                                </table>

                            </div>
                        </div>

                    </div>
                </div>
            </div>
        </div>

    </div>
</main>

@section Scripts {
    <script>
        $(document).ready(function () {

            var table = $('#employeeTable').DataTable();

            loadEmployees(); // ✅ AJAX call

            setTimeout(function () {
                $('.alert-success, .alert-danger').fadeOut('slow');
            }, 5000);

            // ✅ DELETE (UNCHANGED)
            $(document).on('click', '.js-delete', function (e) {
                e.preventDefault();

                var id = $(this).data('id');
                var form = $('#delete-form-' + id);
                var token = form.find('input[name="__RequestVerificationToken"]').val();

                Swal.fire({
                    title: 'Are you sure?',
                    text: 'This employee will be permanently deleted!',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#d33',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: 'Yes, delete it!'
                }).then((result) => {

                    if (result.isConfirmed) {
                        $.ajax({
                            url: form.attr('action'),
                            type: 'POST',
                            data: {
                                id: id,
                                __RequestVerificationToken: token
                            },
                            success: function (res) {
                                if (res.success) {

                                    var row = form.closest('tr');
                                    table.row(row).remove().draw();

                                    Swal.fire('Deleted!', 'Employee deleted successfully.', 'success');
                                } else {
                                    Swal.fire('Error!', res.message, 'error');
                                }
                            },
                            error: function () {
                                Swal.fire('Error!', 'Something went wrong!', 'error');
                            }
                        });
                    }
                });
            });

        });

        // ✅ AJAX FUNCTION
        function loadEmployees() {

            $.ajax({
                url: '/Employees/GetEmployees', // 👈 create this in controller
                type: 'GET',
                success: function (data) {

                    let rows = '';

                    if (data.length === 0) {
                        rows = '<tr><td colspan="9" class="text-center">No Data Found</td></tr>';
                    } else {

                        data.forEach(emp => {

                            let image = emp.empImage
                                ? emp.empImage
                                : '/assets/images/upload.jpg';

                            let status = emp.isActive
                                ? '<span class="text-success fw-bold">Active</span>'
                                : '<span class="text-danger fw-bold">Inactive</span>';

                            let description = emp.discription
                                ? (emp.discription.length > 80
                                    ? emp.discription.substring(0, 80) + "..."
                                    : emp.discription)
                                : '<span class="text-muted fst-italic">No description</span>';

                            rows += `
                            <tr id="row-${emp.id}">
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="me-3">
                                            <img src="${image}"
                                                 class="rounded-circle border"
                                                 style="width:80px;height:80px;object-fit:cover;">
                                        </div>
                                        <div class="d-flex flex-column">
                                            <span class="fw-semibold">${emp.fullName}</span>
                                            <small class="text-muted">ID: ${emp.id}</small>
                                        </div>
                                    </div>
                                </td>
                                <td>${emp.gender || ''}</td>
                                <td>${emp.phoneNumber || ''}</td>
                                <td>${emp.shift || ''}</td>
                                <td>${emp.empRole || ''}</td>
                                <td>${emp.salary || ''}</td>
                                <td>${status}</td>
                                <td>${description}</td>
                                <td class="text-center">
                                    <div class="d-inline-flex gap-1">

                                        <a href="/Employees/Edit/${emp.id}"
                                           class="btn btn-sm btn-light">
                                           <i class="feather-edit-3"></i>
                                        </a>

                                        <form method="post"
                                              action="/Employees/DeleteConfirmed/${emp.id}"
                                              class="d-inline"
                                              id="delete-form-${emp.id}">

                                            <input name="__RequestVerificationToken"
                                                   type="hidden"
                                                   value="${$('input[name="__RequestVerificationToken"]').first().val()}">

                                            <button type="button"
                                                    class="btn btn-sm btn-light js-delete"
                                                    data-id="${emp.id}">
                                                <i class="feather-trash-2"></i>
                                            </button>
                                        </form>

                                    </div>
                                </td>
                            </tr>
                            `;
                        });
                    }

                    $('#employeeTable tbody').html(rows);
                },
                error: function () {
                    alert('Failed to load employees');
                }
            });
        }
    </script>
}