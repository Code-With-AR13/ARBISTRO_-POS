@model ARBISTO_POS.Models.ExpenseType

@{
    ViewData["Title"] = "Edit Expense Type";
}

<!-- [ page-header ] start -->
<div class="page-header">
    <div class="page-header-left d-flex align-items-center">
        <ul class="breadcrumb">
            <li class="breadcrumb-item">
                <a asp-controller="Home" asp-action="Index">Home</a>
            </li>
            <li class="breadcrumb-item">
                <a asp-controller="ExpenseType" asp-action="Index">Expense Types</a>
            </li>
            <li class="breadcrumb-item active">Edit</li>
        </ul>
    </div>
    <div class="page-header-right ms-auto">
        <div class="d-flex align-items-center gap-2 page-header-right-items-wrapper">
            <a asp-controller="ExpenseType" asp-action="Index" class="btn btn-primary">
                <i class="feather-arrow-left me-2"></i>
                <span>Back To Expense Types</span>
            </a>
        </div>
    </div>
</div>
<!-- [ page-header ] end -->
<!-- [ Main Content ] start -->
<div class="main-content">
    <div class="row">
        <div class="col-lg-12">
            <div class="card border-top-0">
                <div class="card-header">
                    <h5 class="card-title">
                        <i class="feather-edit-3 me-2"></i>Edit Expense Type
                    </h5>
                </div>

                <div class="card-body">

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <form asp-action="Edit"
                          asp-controller="ExpenseType"
                          method="post">

                        <!-- hidden Id -->
                        <input type="hidden" asp-for="Id" />

                        <div class="row">

                            <!-- LEFT COLUMN (Empty for layout consistency) -->
                            <div class="col-lg-4 mb-4">
                                <div class="card bg-light">
                                    <div class="card-body text-center">
                                        <span class="text-muted">No image required for Expense Types</span>
                                    </div>
                                </div>
                            </div>

                            <!-- RIGHT COLUMN -->
                            <div class="col-lg-8">

                                <!-- PAYMENT METHOD NAME -->
                                <div class="mb-3">
                                    <label asp-for="ExpenseName" class="form-label fw-semibold">
                                        Payment Method Name <span class="text-danger">*</span>
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text">
                                            <i class="feather-tag"></i>
                                        </span>
                                        <input asp-for="ExpenseName"
                                               class="form-control"
                                               placeholder="e.g. Cash, Credit Card" />
                                    </div>
                                    <span asp-validation-for="ExpenseName" class="text-danger small"></span>
                                </div>

                                <!-- DESCRIPTION -->
                                <div class="mb-3">
                                    <label asp-for="ExpDescription" class="form-label fw-semibold">
                                        Description
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text">
                                            <i class="feather-file-text"></i>
                                        </span>
                                        <textarea asp-for="ExpDescription"
                                                  class="form-control"
                                                  rows="4"
                                                  placeholder="Optional description..."></textarea>
                                    </div>
                                    <span asp-validation-for="ExpDescription" class="text-danger small"></span>
                                </div>

                                <!-- ACTIONS -->
                                <div class="d-flex gap-2 justify-content-end mt-4">
                                    <a asp-action="Index" class="btn btn-light">
                                        <i class="feather-x me-1"></i>Cancel
                                    </a>
                                    <button type="submit" class="btn btn-primary">
                                        <i class="feather-save me-1"></i>Update Expense Type
                                    </button>
                                </div>

                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- [ Main Content ] end -->
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
