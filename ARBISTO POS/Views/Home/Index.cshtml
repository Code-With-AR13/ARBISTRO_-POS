@{
    ViewData["Title"] = "Dashboard";
}

<div class="main-content">
    <div class="row">

        <!-- Total Orders -->
        <div class="col-xxl-3 col-md-6">
            <div class="card stretch stretch-full">
                <div class="card-body">
                    <div class="d-flex align-items-start justify-content-between mb-4">
                        <div class="d-flex gap-4 align-items-center">
                            <div class="avatar-text avatar-lg bg-gray-200">
                                <i class="feather-shopping-cart"></i>
                            </div>
                            <div>
                                <div class="fs-4 fw-bold text-dark">
                                    <span id="totalOrders">0</span>/<span id="totalOrdersAll">0</span>
                                </div>
                                <h3 class="fs-13 fw-semibold">Total Orders</h3>
                            </div>
                        </div>
                        <i class="feather-more-vertical"></i>
                    </div>

                    <div class="progress mt-2 ht-3">
                        <div id="ordersProgress" class="progress-bar bg-primary" style="width: 0%"></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Total Paid -->
        <div class="col-xxl-3 col-md-6">
            <div class="card stretch stretch-full">
                <div class="card-body">
                    <div class="fs-4 fw-bold text-dark">
                        <span id="totalPaid">0</span>/<span id="totalPaidAll">0</span>
                    </div>
                    <h3 class="fs-13 fw-semibold">Total Paid</h3>
                    <div class="progress mt-2 ht-3">
                        <div id="paidProgress" class="progress-bar bg-warning" style="width: 0%"></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Total Unpaid -->
        <div class="col-xxl-3 col-md-6">
            <div class="card stretch stretch-full">
                <div class="card-body">
                    <div class="fs-4 fw-bold text-dark">
                        <span id="totalUnpaid">0</span>/<span id="totalUnpaidAll">0</span>
                    </div>
                    <h3 class="fs-13 fw-semibold">Total Unpaid</h3>
                    <div class="progress mt-2 ht-3">
                        <div id="unpaidProgress" class="progress-bar bg-success" style="width: 0%"></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Total Expense -->
        <div class="col-xxl-3 col-md-6">
            <div class="card stretch stretch-full">
                <div class="card-body">
                    <div class="fs-4 fw-bold text-dark">
                        <span id="totalExpense">0</span> PKR
                    </div>
                    <h3 class="fs-13 fw-semibold">Total Expense</h3>
                    <div class="progress mt-2 ht-3">
                        <div id="expenseProgress" class="progress-bar bg-danger" style="width: 0%"></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- GRAPH -->
        <div class="col-xxl-8">
            <div class="card stretch stretch-full">
                <div class="card-header">
                    <h5 class="card-title">Payment Record</h5>
                </div>
                <div class="card-body p-0">
                    <div id="payment-records-chart"></div>
                </div>
            </div>
        </div>

        <!-- LEADS OVERVIEW -->
        <div class="col-xxl-4">
            <div class="card stretch stretch-full">
                <div class="card-header">
                    <h5 class="card-title">Leads Overview</h5>
                </div>
                <div class="card-body">
                    <div id="leads-overview-donut"></div>
                </div>
            </div>
        </div>

        <!-- LATEST LEADS -->
        <div class="col-xxl-12">
            <div class="card stretch stretch-full">
                <div class="card-header">
                    <h5 class="card-title">Latest Leads</h5>
                </div>
                <div class="card-body">
                    <table id="latestLeadsTable" class="table table-striped">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Phone</th>
                                <th>Status</th>
                                <th>Date</th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
            </div>
        </div>

    </div>
</div>

@section Scripts {

<script>
    let paymentChart = null;
    let leadsChart = null;

    $(document).ready(function () {

        loadDashboard();
        loadTable();

        function loadDashboard() {

            $.ajax({
                url: '/Home/GetDashboardData',
                type: 'GET',
                success: function (data) {

                    // COUNTERS
                    $('#totalOrders').text(data.totalOrders);
                    $('#totalOrdersAll').text(data.totalOrdersAll);

                    $('#totalPaid').text(data.totalPaid);
                    $('#totalUnpaid').text(data.totalUnpaid);

                    $('#totalExpense').text(data.totalExpense);

                    // PROGRESS
                    $('#paidProgress').css('width', data.paidPercent + '%');
                    $('#unpaidProgress').css('width', data.unpaidPercent + '%');

                    // ======================
                    // 🔥 DESTROY OLD CHARTS
                    // ======================
                    if (paymentChart !== null) {
                        paymentChart.destroy();
                    }

                    if (leadsChart !== null) {
                        leadsChart.destroy();
                    }

                    // ======================
                    // 📊 PAYMENT CHART (REAL DYNAMIC FIX)
                    // ======================

                    let hasData = data.chartPayments && data.chartPayments.some(x => Number(x) > 0);

                    let chartData = hasData
                        ? data.chartPayments.map(x => Number(x))
                        : [];

                    let chartDates = hasData
                        ? data.chartDates
                        : [];

                    var options = {
                        chart: {
                            type: 'line',
                            height: 300,
                            toolbar: { show: false }
                        },
                        series: [{
                            name: 'Payments',
                            data: chartData
                        }],
                        xaxis: {
                            categories: chartDates
                        },
                        stroke: {
                            curve: 'smooth',
                            width: hasData ? 3 : 0 // hide line if no data
                        },
                        markers: {
                            size: hasData ? 5 : 0 // hide dots
                        },
                        dataLabels: {
                            enabled: false
                        },
                        noData: {
                            text: "No Payment Data Available"
                        }
                    };

                    paymentChart = new ApexCharts(
                        document.querySelector("#payment-records-chart"),
                        options
                    );

                    paymentChart.render();

                    // ======================
                    // 🍩 DONUT CHART (ALREADY PERFECT)
                    // ======================
                    let donutSeries = [
                        Number(data.totalPaid),
                        Number(data.totalUnpaid)
                    ];

                    var donutOptions = {
                        chart: {
                            type: 'donut'
                        },
                        series: donutSeries,
                        labels: ["Paid", "Unpaid"],
                        stroke: {
                            width: 1
                        }
                    };

                    leadsChart = new ApexCharts(
                        document.querySelector("#leads-overview-donut"),
                        donutOptions
                    );

                    leadsChart.render();
                },
                error: function () {
                    console.log("Dashboard data load failed");
                }
            });
        }

        function loadTable() {

            if ($.fn.DataTable.isDataTable('#latestLeadsTable')) {
                $('#latestLeadsTable').DataTable().destroy();
            }

            $('#latestLeadsTable').DataTable({
                ajax: {
                    url: '/Home/GetLatestLeads',
                    type: 'GET',
                    dataSrc: 'data'
                },
                columns: [
                    { data: 'name' },
                    { data: 'phone' },
                    { data: 'status' },
                    { data: 'date' }
                ]
            });
        }

    });
</script>
}
    