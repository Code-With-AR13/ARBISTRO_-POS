@{
    ViewData["Title"] = "Dashboard";
}

<style>

/* WELCOME */
.welcome-card {
    min-height: 160px;
    border-radius: 20px;
    padding: 30px 40px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    color: #fff;
}

.welcome-left h3 {
    font-size: 42px;
    font-weight: 800;
    color: white;
}

.welcome-left p {
    font-size: 20px;
    margin-top: 10px;
    color: #e5e7eb;
}

.welcome-right img {
    width: 130px;
}

/* 🔥 NEW CARD DESIGN */
.dashboard-card {
    border-radius: 14px;
    padding: 20px;
    background: #fff;
    box-shadow: 0 6px 18px rgba(0,0,0,0.05);
    transition: 0.3s ease;
    border-top: 4px solid #3b82f6;
    position: relative;
}

.dashboard-card:hover {
    transform: translateY(-5px);
}

/* COLORS */
.border-blue { border-top-color: #3b82f6; }
.border-green { border-top-color: #22c55e; }
.border-orange { border-top-color: #f59e0b; }
.border-purple { border-top-color: #a855f7; }
.border-red { border-top-color: #ef4444; }
.border-gray { border-top-color: #6b7280; }
.border-teal { border-top-color: #14b8a6; }

/* HEADER */
.card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

/* ICON */
.icon-box {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
}

.icon-blue { background: #e0edff; color: #3b82f6; }
.icon-green { background: #e7f9ef; color: #22c55e; }
.icon-orange { background: #fff4e5; color: #f59e0b; }
.icon-purple { background: #f3e8ff; color: #a855f7; }
.icon-red { background: #fee2e2; color: #ef4444; }
.icon-gray { background: #f1f5f9; color: #6b7280; }
.icon-teal { background: #e6fffb; color: #14b8a6; }

/* TITLE */
.card-title {
    font-size: 13px;
    color: #94a3b8;
    margin-top: 10px;
    text-transform: uppercase;
}

/* VALUE */
.dashboard-card h2 {
    font-size: 26px;
    font-weight: 700;
    margin-top: 5px;
    color: #1e293b;
}

/* BADGE */
.badge-status {
    font-size: 11px;
    padding: 4px 10px;
    border-radius: 20px;
    background: #f1f5f9;
    color: #64748b;
}

/* HIDE MINI CHARTS (IMPORTANT) */
.dashboard-card canvas {
    display: none !important;
}

/* MAIN CHARTS */
#mainLineChart,
#mainDonutChart {
    height: 320px !important;
}

/* ORDER ID STYLE */
.order-id {
    font-weight: 600;
    color: #1e293b;
}
</style>

<div class="main-content">

    <!-- WELCOME -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="welcome-card bg-primary">
                <div class="welcome-left">
                    <h3>Welcome Back</h3>
                    <p id="liveDateTime">Loading...</p>
                </div>
                <div class="welcome-right">
                    <img src="/images/logo_white_transparent.png" />
                </div>
            </div>
        </div>
    </div>

    <!-- CARDS -->
    <div class="row g-4">

        <!-- Sale -->
        <div class="col-md-4">
            <div class="dashboard-card border-blue">
                <div class="card-header">
                    <div class="icon-box icon-blue"><i class="fas fa-chart-line"></i></div>
                    <span class="badge-status">Sales</span>
                </div>
                <div class="card-title">Total Sale</div>
                <h2>Rs <span id="totalSale">0</span></h2>
                <canvas id="saleChart"></canvas>
            </div>
        </div>

        <!-- Cost -->
        <div class="col-md-4">
            <div class="dashboard-card border-green">
                <div class="card-header">
                    <div class="icon-box icon-green"><i class="fas fa-coins"></i></div>
                    <span class="badge-status">Cost</span>
                </div>
                <div class="card-title">Total Cost</div>
                <h2>Rs <span id="totalCost">0</span></h2>
                <canvas id="costChart"></canvas>
            </div>
        </div>

        <!-- Discount -->
        <div class="col-md-4">
            <div class="dashboard-card border-orange">
                <div class="card-header">
                    <div class="icon-box icon-orange"><i class="fas fa-tags"></i></div>
                    <span class="badge-status">Discount</span>
                </div>
                <div class="card-title">Discount</div>
                <h2>Rs <span id="totalDiscount">0</span></h2>
                <canvas id="discountChart"></canvas>
            </div>
        </div>

        <!-- Profit -->
        <div class="col-md-4">
            <div class="dashboard-card border-purple">
                <div class="card-header">
                    <div class="icon-box icon-purple"><i class="fas fa-chart-pie"></i></div>
                    <span class="badge-status">Profit</span>
                </div>
                <div class="card-title">Profit</div>
                <h2>Rs <span id="totalProfit">0</span></h2>
                <canvas id="profitChart"></canvas>
            </div>
        </div>

        <!-- Expenses -->
        <div class="col-md-4">
            <div class="dashboard-card border-gray">
                <div class="card-header">
                    <div class="icon-box icon-gray"><i class="fas fa-wallet"></i></div>
                    <span class="badge-status">Expenses</span>
                </div>
                <div class="card-title">Expenses</div>
                <h2>Rs <span id="totalExpenses">0</span></h2>
                <canvas id="expensesChart"></canvas>
            </div>
        </div>

        <!-- Profit After -->
        <div class="col-md-4">
            <div class="dashboard-card border-teal">
                <div class="card-header">
                    <div class="icon-box icon-teal"><i class="fas fa-chart-area"></i></div>
                    <span class="badge-status">Net</span>
                </div>
                <div class="card-title">Profit After</div>
                <h2>Rs <span id="profitAfterExpenses">0</span></h2>
                <canvas id="profitAfterChart"></canvas>
            </div>
        </div>

    </div>

    <!-- MAIN GRAPHS -->
    <div class="row mt-4">

        <div class="col-md-8">
            <div class="card p-3">
                <h5>Revenue & Expenses</h5>
                <canvas id="mainLineChart"></canvas>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card p-3">
                <h5>Sales Distribution</h5>
                <canvas id="mainDonutChart"></canvas>
            </div>
        </div>

    </div>

</div>


<!-- ✅ ONLY THIS SECTION UPDATED -->
<div class="row mt-4 px-4"> <!-- ✅ SAME SIDE SPACING -->

    <div class="col-12">
        <div class="card stretch stretch-full">

            <div class="card-header d-flex align-items-center justify-content-between">
                <h5 class="card-title mb-0">
                    <i class="feather-list me-2"></i>Recent Orders
                </h5>
            </div>

            <div class="card-body">

                <div class="table-responsive">
                    <table class="table table-hover align-middle dataTable" id="ordersTable">
                        <thead class="table-light">
                            <tr>
                                <th>Order No</th>
                                <th>Customer</th>
                                <th>Total</th>
                                <th>Date</th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>

            </div>

        </div>
    </div>

</div>
@section Scripts {
<script>

// ✅ ORIGINAL VARIABLES
let charts = {};
let mainLineChart;
let mainDonutChart;

// ✅ ORIGINAL READY FUNCTION
$(document).ready(function () {
    loadDashboard();
    loadMainCharts();
    startDateTime();
});

// ✅ DATE TIME
function startDateTime() {
    setInterval(() => {
        let now = new Date();
        $('#liveDateTime').text(
            now.toLocaleDateString('en-PK') + " | " +
            now.toLocaleTimeString('en-PK')
        );
    }, 1000);
}

// ✅ SAFE NUMBER
function toNumber(v) {
    let n = Number(v);
    return isNaN(n) ? 0 : n;
}

// ✅ DASHBOARD DATA
function loadDashboard() {
    $.get('/Home/GetDashboardData', function (data) {

        $('#totalSale').text(toNumber(data.totalSale).toLocaleString());
        $('#totalCost').text(toNumber(data.totalCost).toLocaleString());
        $('#totalDiscount').text(toNumber(data.totalDiscount).toLocaleString());
        $('#totalProfit').text(toNumber(data.totalProfit).toLocaleString());
        $('#totalTax').text(toNumber(data.totalTax).toLocaleString());
        $('#totalExpenses').text(toNumber(data.totalExpenses).toLocaleString());
        $('#profitAfterExpenses').text(toNumber(data.profitAfterExpenses).toLocaleString());

        // ✅ MINI CHARTS (RESTORED)
        createMiniChart('saleChart','#3b82f6');
        createMiniChart('costChart','#22c55e');
        createMiniChart('discountChart','#f59e0b');
        createMiniChart('profitChart','#a855f7');
        createMiniChart('taxChart','#ef4444');
        createMiniChart('expensesChart','#6b7280');
        createMiniChart('profitAfterChart','#14b8a6');
    });
}

// ✅ MINI CHART FUNCTION (RESTORED)
function createMiniChart(id,color){
    if(charts[id]) charts[id].destroy();

    charts[id]=new Chart(document.getElementById(id),{
        type:'line',
        data:{
            labels:['','','','','','','',''],
            datasets:[{
                data:Array.from({length:8},()=>Math.random()*100),
                borderColor:color,
                backgroundColor:color+'33',
                fill:true,
                tension:0.4,
                pointRadius:0
            }]
        },
        options:{
            responsive:true,
            maintainAspectRatio:false,
            plugins:{legend:{display:false}},
            scales:{x:{display:false},y:{display:false}}
        }
    });
}

// ✅ MAIN CHARTS (FULLY RESTORED)
function loadMainCharts(){

    $.get('/Home/GetChartData',function(data){

        let labels = data.map(x => "M" + x.month);
        let sales = data.map(x => toNumber(x.sale));
        let costs = data.map(x => toNumber(x.cost));

        if (sales.length === 0) {
            labels = ['No Data'];
            sales = [0];
            costs = [0];
        }

        if (sales.every(v => v === 0) && costs.every(v => v === 0)) {
            sales = [0.1];
            costs = [0.1];
        }

        if(mainLineChart) mainLineChart.destroy();
        if(mainDonutChart) mainDonutChart.destroy();

        mainLineChart = new Chart(document.getElementById('mainLineChart'),{
            type:'line',
            data:{
                labels:labels,
                datasets:[
                    {
                        label:'Sales',
                        data:sales,
                        borderColor:'#0d6efd',
                        backgroundColor:'rgba(13,110,253,0.2)',
                        fill:true,
                        tension:0.45
                    },
                    {
                        label:'Cost',
                        data:costs,
                        borderColor:'#dc3545',
                        backgroundColor:'rgba(220,53,69,0.2)',
                        fill:true,
                        tension:0.45
                    }
                ]
            },
            options:{ responsive:true, maintainAspectRatio:false }
        });

        let totalSales = sales.reduce((a,b)=>a+b,0);
        let totalCosts = costs.reduce((a,b)=>a+b,0);

        let donutData, donutLabels, donutColors;

        if (totalSales === 0 && totalCosts === 0) {
            donutData = [1];
            donutLabels = ['No Data'];
            donutColors = ['#e5e7eb'];
        } else {
            donutData = [totalSales, totalCosts];
            donutLabels = ['Sales','Cost'];
            donutColors = ['#0d6efd','#dc3545'];
        }

        mainDonutChart = new Chart(document.getElementById('mainDonutChart'),{
            type:'doughnut',
            data:{
                labels:donutLabels,
                datasets:[{ data:donutData, backgroundColor:donutColors }]
            },
            options:{ responsive:true, maintainAspectRatio:false }
        });

    });
}

// ✅ DATATABLE (UPDATED LIKE SALE ORDER)
let ordersTable;

$(document).ready(function () {

    ordersTable = $('#ordersTable').DataTable({
        order: [[0, 'desc']],
       
        ajax: {
            url: '/Home/GetOrders',
            type: 'GET',
            dataSrc: 'data' // ✅ VERY IMPORTANT (matches controller)
        },

        columns: [
            {
                data: null,
                render: function (data) {
                    return `
                    <div class="d-flex flex-column">
                        <span class="fw-semibold">ORD-${data.orderId}</span>
                        <small class="text-muted">
                            ${formatDate(data.orderDate)}
                        </small>
                    </div>`;
                }
            },
            {
                data: "customerName",
                render: function (data) {
                    return `<span class="fw-semibold">${data || 'Walk-in'}</span>`;
                }
            },
            {
                data: "totalAmount",
                render: function (data) {
                    return `<span class="fw-semibold text-dark">
                        Rs ${Number(data || 0).toLocaleString()}
                    </span>`;
                }
            },
            {
                data: "orderDate",
                render: function (data) {
                    return `<span class="text-muted">${formatDate(data)}</span>`;
                }
            }
        ]
    });

    // ✅ AUTO REFRESH (LIVE DATA)
    setInterval(function () {
        ordersTable.ajax.reload(null, false);
    }, 5000);

});

// ✅ DATE FORMAT
function formatDate(dateString) {
    let date = new Date(dateString);
    return date.toLocaleString('en-PK');
}

</script>
}
